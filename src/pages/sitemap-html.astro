---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { SITE, SERVICES, LOCATIONS_TIER1 } from '@/lib/constants';

const breadcrumbs = [{ label: 'Sitemap', href: '/sitemap-html/' }];

const mainPages = [
  { title: 'Home', href: '/' },
  { title: 'About Us', href: '/about/' },
  { title: 'Contact', href: '/contact/' },
  { title: 'Get a Quote', href: 'https://nexfield.pro/crm/book?u=137' },
  { title: 'Our Process', href: '/our-process/' },
  { title: 'Gallery', href: '/gallery/' },
  { title: 'Financing', href: '/financing/' },
  { title: 'FAQ', href: '/faq/' },
  { title: 'Reviews', href: '/reviews/' },
];

const costGuides = [
  { title: 'Kitchen Remodel Cost', slug: 'kitchen-remodel-cost-seattle' },
  { title: 'Bathroom Remodel Cost', slug: 'bathroom-remodel-cost-seattle' },
  { title: 'Cabinet Refacing Cost', slug: 'cabinet-refacing-cost' },
  { title: 'Countertop Installation Cost', slug: 'countertop-installation-cost' },
  { title: 'Shower Remodel Cost', slug: 'shower-remodel-cost' },
];

const blogPosts = [
  { title: '15 Kitchen Remodel Ideas for Seattle Homes in 2026', slug: 'kitchen-remodel-ideas-seattle' },
  { title: '10 Bathroom Remodel Ideas That Add Value to Your Seattle Home', slug: 'bathroom-remodel-ideas-seattle' },
  { title: 'Quartz vs Granite Countertops', slug: 'quartz-vs-granite-countertops-seattle' },
  { title: 'Seattle Remodeling Permits: What Homeowners Need to Know', slug: 'do-you-need-permit-remodel-seattle' },
  { title: 'How Long Does a Kitchen Remodel Take?', slug: 'how-long-kitchen-remodel-take' },
  { title: 'Small Bathroom Remodel Ideas', slug: 'small-bathroom-remodel-ideas' },
  { title: 'Kitchen Remodel ROI in Seattle 2026', slug: 'kitchen-remodel-roi-seattle-2026' },
  { title: 'Kitchen Cabinet Styles 2026', slug: 'kitchen-cabinet-styles-2026' },
  { title: 'Kitchen Lighting Design Guide', slug: 'kitchen-lighting-design-guide' },
  { title: 'Open Concept Kitchen Remodel', slug: 'open-concept-kitchen-remodel' },
  { title: 'Hardwood vs LVP Flooring in Seattle', slug: 'hardwood-vs-lvp-flooring-seattle' },
  { title: 'Walk-In Shower Ideas', slug: 'walk-in-shower-ideas' },
  { title: 'Seattle Bathroom Tile Trends', slug: 'seattle-bathroom-tile-trends' },
  { title: 'Master Bathroom Remodel Checklist', slug: 'master-bathroom-remodel-checklist' },
  { title: 'Bathroom Vanity Buying Guide', slug: 'bathroom-vanity-buying-guide' },
  { title: 'Aging in Place Bathroom Remodel', slug: 'aging-in-place-bathroom-remodel' },
];

const blogCategories = [
  { title: 'Kitchen', href: '/blog/category/kitchen/' },
  { title: 'Bathroom', href: '/blog/category/bathroom/' },
  { title: 'Tips', href: '/blog/category/tips/' },
];

const reviewCategories = [
  { title: 'Kitchen Remodeling Reviews', href: '/reviews/kitchen-remodeling/' },
  { title: 'Bathroom Remodeling Reviews', href: '/reviews/bathroom-remodeling/' },
  { title: 'Cabinet Refacing Reviews', href: '/reviews/cabinet-refacing/' },
  { title: 'Countertop Installation Reviews', href: '/reviews/countertop-installation/' },
];

const topCities = LOCATIONS_TIER1.map((loc) => ({ title: `${loc.city}, WA`, slug: loc.slug }));

---

<BaseLayout
  title="Sitemap | Best Kitchen and Bathroom Remodeling"
  description="Complete sitemap for Best Kitchen and Bathroom Remodeling. Find all our pages including services, areas served, cost guides, and blog posts."
  canonical={`${SITE.url}/sitemap-html/`}
>
  <SchemaBreadcrumb items={breadcrumbs} />

  <!-- Hero -->
  <section class="bg-primary pt-32 pb-12">
    <Container>
      <div class="max-w-3xl" data-reveal>
        <p class="text-accent font-semibold uppercase tracking-wider text-sm mb-3">Site Navigation</p>
        <h1 class="text-4xl md:text-5xl font-[family-name:var(--font-heading)] text-white mb-4">Sitemap</h1>
        <p class="text-lg text-white/80 leading-relaxed">
          A complete directory of all pages on our website. Find exactly what you're looking for.
        </p>
      </div>
    </Container>
  </section>

  <!-- Sitemap Content -->
  <section class="py-16 lg:py-20">
    <Container>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 lg:gap-16">

        <!-- Main Pages -->
        <div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-dark-text mb-4 pb-2 border-b-2 border-accent">Main Pages</h2>
          <ul class="space-y-2.5">
            {mainPages.map((page) => (
              <li>
                <a href={page.href} class="text-muted hover:text-accent transition-colors">
                  {page.title}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Services -->
        <div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-dark-text mb-4 pb-2 border-b-2 border-accent">Services</h2>
          <ul class="space-y-2.5">
            <li>
              <a href="/services/" class="text-muted hover:text-accent transition-colors font-medium">
                All Services
              </a>
            </li>
            {SERVICES.map((service) => (
              <li>
                <a href={`/services/${service.slug}/`} class="text-muted hover:text-accent transition-colors">
                  {service.title}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Cost Guides -->
        <div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-dark-text mb-4 pb-2 border-b-2 border-accent">Cost Guides</h2>
          <ul class="space-y-2.5">
            <li>
              <a href="/cost-guides/" class="text-muted hover:text-accent transition-colors font-medium">
                All Cost Guides
              </a>
            </li>
            {costGuides.map((guide) => (
              <li>
                <a href={`/cost-guides/${guide.slug}/`} class="text-muted hover:text-accent transition-colors">
                  {guide.title}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Blog -->
        <div class="md:col-span-2 lg:col-span-1">
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-dark-text mb-4 pb-2 border-b-2 border-accent">Blog</h2>
          <ul class="space-y-2.5">
            <li>
              <a href="/blog/" class="text-muted hover:text-accent transition-colors font-medium">
                All Blog Posts
              </a>
            </li>
            {blogPosts.map((post) => (
              <li>
                <a href={`/blog/${post.slug}/`} class="text-muted hover:text-accent transition-colors">
                  {post.title}
                </a>
              </li>
            ))}
          </ul>
          <h3 class="text-lg font-semibold font-[family-name:var(--font-heading)] text-dark-text mt-6 mb-3">Blog Categories</h3>
          <ul class="space-y-2.5">
            {blogCategories.map((cat) => (
              <li>
                <a href={cat.href} class="text-muted hover:text-accent transition-colors">
                  {cat.title}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Reviews by Service -->
        <div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-dark-text mb-4 pb-2 border-b-2 border-accent">Reviews by Service</h2>
          <ul class="space-y-2.5">
            <li>
              <a href="/reviews/" class="text-muted hover:text-accent transition-colors font-medium">
                All Reviews
              </a>
            </li>
            {reviewCategories.map((cat) => (
              <li>
                <a href={cat.href} class="text-muted hover:text-accent transition-colors">
                  {cat.title}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Areas Served -->
        <div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-dark-text mb-4 pb-2 border-b-2 border-accent">Areas Served</h2>
          <ul class="space-y-2.5">
            <li>
              <a href="/areas-served/" class="text-muted hover:text-accent transition-colors font-medium">
                All Areas
              </a>
            </li>
            {topCities.map((city) => (
              <li>
                <a href={`/areas-served/${city.slug}/`} class="text-muted hover:text-accent transition-colors">
                  {city.title}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-dark-text mb-4 pb-2 border-b-2 border-accent">Legal</h2>
          <ul class="space-y-2.5">
            <li>
              <a href="/privacy/" class="text-muted hover:text-accent transition-colors">
                Privacy Policy
              </a>
            </li>
            <li>
              <a href="/terms/" class="text-muted hover:text-accent transition-colors">
                Terms of Service
              </a>
            </li>
            <li>
              <a href="/sitemap-index.xml" class="text-muted hover:text-accent transition-colors">
                XML Sitemap
              </a>
            </li>
          </ul>
        </div>

      </div>
    </Container>
  </section>
</BaseLayout>
