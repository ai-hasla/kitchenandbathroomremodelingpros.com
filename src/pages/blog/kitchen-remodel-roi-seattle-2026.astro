const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is the average ROI for a kitchen remodel in Seattle in 2026?',
      acceptedAnswer: {
        '@type': 'Answer',
