---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { SITE } from '@/lib/constants';

const breadcrumbs = [
  { label: 'Blog', href: '/blog/' },
  { label: 'Bathroom', href: '/blog/category/bathroom/' },
];

const posts = [
  {
    title: '10 Bathroom Remodel Ideas That Add Value to Your Seattle Home',
    slug: 'bathroom-remodel-ideas-seattle',
    excerpt: 'Discover bathroom renovation ideas that not only look stunning but also boost your home\'s resale value in the competitive Seattle market.',
    image: '/images/blog-bathroom-ideas.jpg',
    category: 'Bathroom',
    date: '2026-02-12',
    readTime: '9 min read',
  },
  {
    title: '25 Small Bathroom Remodel Ideas That Maximize Space',
    slug: 'small-bathroom-remodel-ideas',
    excerpt: 'Smart design strategies and creative solutions to make the most of a compact bathroom. Storage hacks, layout tips, and fixtures that save space without sacrificing style.',
    image: '/images/blog-farmhouse-kitchen.jpg',
    category: 'Bathroom',
    date: '2026-01-15',
    readTime: '7 min read',
  },
  {
    title: 'Seattle Bathroom Tile Trends 2026: Expert Design Guide',
    slug: 'seattle-bathroom-tile-trends',
    excerpt: 'Large format, natural stone, terrazzo, and patterned cement — discover the tile trends Seattle designers are using in 2026.',
    image: '/images/blog-bathroom-ideas.jpg',
    category: 'Bathroom',
    date: '2026-02-28',
    readTime: '7 min read',
  },
  {
    title: '12 Walk-In Shower Ideas That Transform Your Bathroom',
    slug: 'walk-in-shower-ideas',
    excerpt: 'Frameless glass, curbless entries, dual showerheads, and more — stunning walk-in shower designs for every budget.',
    image: '/images/blog-bathroom-ideas.jpg',
    category: 'Bathroom',
    date: '2026-01-20',
    readTime: '7 min read',
  },
  {
    title: 'Master Bathroom Remodel Checklist: 15 Things to Plan Before You Start',
    slug: 'master-bathroom-remodel-checklist',
    excerpt: 'Don\'t start your bathroom renovation without this comprehensive planning checklist covering budget, permits, layout, and more.',
    image: '/images/blog-farmhouse-kitchen.jpg',
    category: 'Bathroom',
    date: '2025-12-28',
    readTime: '9 min read',
  },
  {
    title: 'Aging-in-Place Bathroom Remodel: A Complete Guide for Seattle Homeowners',
    slug: 'aging-in-place-bathroom-remodel',
    excerpt: 'ADA-compliant designs, grab bars, curbless showers, and universal design principles for safe, beautiful bathrooms at every stage of life.',
    image: '/images/blog-bathroom-ideas.jpg',
    category: 'Bathroom',
    date: '2025-12-10',
    readTime: '9 min read',
  },
  {
    title: 'Bathroom Vanity Buying Guide: Sizes, Styles & Installation Tips',
    slug: 'bathroom-vanity-buying-guide',
    excerpt: 'Single vs double, floating vs freestanding — find the perfect vanity for your bathroom with our comprehensive buying guide.',
    image: '/images/blog-remodel-process.jpg',
    category: 'Bathroom',
    date: '2025-11-28',
    readTime: '7 min read',
  },
];
---

<BaseLayout
  title="Bathroom Remodeling Blog | Tips & Ideas | Best KB Remodeling"
  description="Bathroom remodeling inspiration, tile trends, vanity guides, and expert planning tips for Seattle homeowners. Design ideas for every budget and style."
  canonical={`${SITE.url}/blog/category/bathroom/`}
  ogImage="/images/og/og-blog.png"
>
  <SchemaBreadcrumb items={breadcrumbs} />

  <!-- Hero -->
  <section class="bg-primary pt-32 pb-16">
    <Container>
      <div class="max-w-3xl" data-reveal>
        <p class="text-accent font-semibold uppercase tracking-wider text-sm mb-3">Bathroom Remodeling</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[family-name:var(--font-heading)] text-white mb-6">Bathroom Remodeling Blog</h1>
        <p class="text-lg text-white/80 leading-relaxed">
          Tile trends, vanity guides, walk-in shower ideas, and practical planning advice for your bathroom remodel in Seattle.
        </p>
      </div>
    </Container>
  </section>

  <!-- Category Nav -->
  <section class="py-6 border-b border-border bg-white">
    <Container>
      <nav class="flex flex-wrap items-center gap-3">
        <a href="/blog/" class="text-sm font-medium text-muted hover:text-accent transition-colors">All Posts</a>
        <span class="text-border">|</span>
        <a href="/blog/category/kitchen/" class="text-sm font-medium text-muted hover:text-accent transition-colors">Kitchen</a>
        <span class="text-border">|</span>
        <span class="text-sm font-bold text-accent">Bathroom</span>
        <span class="text-border">|</span>
        <a href="/blog/category/tips/" class="text-sm font-medium text-muted hover:text-accent transition-colors">Tips</a>
      </nav>
    </Container>
  </section>

  <!-- Blog Grid -->
  <section class="py-20">
    <Container>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" data-reveal-stagger>
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}/`}
            class="group bg-white border border-border rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300"
          >
            <div class="aspect-[16/10] overflow-hidden relative">
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width="800"
                height="500"
                loading="lazy"
              />
              <span class="absolute top-4 left-4 bg-accent text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">
                {post.category}
              </span>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 text-sm text-muted mb-3">
                <time datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>
                <span>&middot;</span>
                <span>{post.readTime}</span>
              </div>
              <h2 class="text-lg font-[family-name:var(--font-heading)] text-primary mb-2 group-hover:text-accent transition-colors leading-snug">{post.title}</h2>
              <p class="text-body-text text-sm leading-relaxed">{post.excerpt}</p>
              <span class="inline-flex items-center gap-1.5 text-accent font-medium text-sm mt-4 group-hover:gap-2.5 transition-all">
                Read Article
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-light">
    <Container>
      <div class="text-center max-w-2xl mx-auto" data-reveal>
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">Ready to Remodel Your Bathroom?</h2>
        <p class="text-body-text text-lg mb-8">
          From spa-inspired retreats to functional family bathrooms, we bring your vision to life. Get a free estimate today.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="https://nexfield.pro/crm/book?u=137" target="_blank" rel="noopener noreferrer" variant="primary" size="lg">Get a Free Estimate</Button>
          <Button href="/services/bathroom-remodeling/" variant="outline" size="lg">Bathroom Remodeling Services</Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
