---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { SITE } from '@/lib/constants';

const breadcrumbs = [
  { label: 'Blog', href: '/blog/' },
  { label: 'Kitchen', href: '/blog/category/kitchen/' },
];

const posts = [
  {
    title: '15 Kitchen Remodel Ideas for Seattle Homes in 2026',
    slug: 'kitchen-remodel-ideas-seattle',
    excerpt: 'From waterfall islands to two-tone cabinets, explore the top kitchen remodeling trends that are perfect for Pacific Northwest homes.',
    image: '/images/blog-kitchen-ideas.jpg',
    category: 'Kitchen',
    date: '2026-02-20',
    readTime: '10 min read',
  },
  {
    title: 'How to Choose the Right Countertop Material for Your Kitchen',
    slug: 'quartz-vs-granite-countertops-seattle',
    excerpt: 'Quartz vs. granite vs. marble vs. butcher block: a comprehensive comparison to help you pick the perfect countertop for your lifestyle and budget.',
    image: '/images/blog-remodel-process.jpg',
    category: 'Kitchen',
    date: '2026-01-28',
    readTime: '8 min read',
  },
  {
    title: 'Kitchen Cabinet Styles 2026: What\'s Trending in Seattle',
    slug: 'kitchen-cabinet-styles-2026',
    excerpt: 'From shaker to flat-panel to two-tone finishes, explore the hottest cabinet trends transforming Seattle kitchens right now.',
    image: '/images/blog-kitchen-ideas.jpg',
    category: 'Kitchen',
    date: '2026-03-01',
    readTime: '8 min read',
  },
  {
    title: 'How Long Does a Kitchen Remodel Take? Timeline Guide 2026',
    slug: 'how-long-kitchen-remodel-take',
    excerpt: 'A realistic breakdown of kitchen remodel timelines from planning to completion. Learn what affects the schedule and how to avoid common delays.',
    image: '/images/blog-modern-kitchen.jpg',
    category: 'Kitchen',
    date: '2025-12-05',
    readTime: '5 min read',
  },
  {
    title: 'Kitchen Remodel ROI in Seattle: Is It Worth the Investment in 2026?',
    slug: 'kitchen-remodel-roi-seattle-2026',
    excerpt: 'Data-backed analysis of kitchen remodel return on investment in Seattle\'s housing market. Which upgrades add the most value?',
    image: '/images/blog-kitchen-remodel.jpg',
    category: 'Kitchen',
    date: '2026-02-05',
    readTime: '8 min read',
  },
  {
    title: 'Kitchen Lighting Design: Layered Lighting Ideas for Seattle Homes',
    slug: 'kitchen-lighting-design-guide',
    excerpt: 'Master the three layers of kitchen lighting — ambient, task, and accent — to create a functional and inviting space.',
    image: '/images/blog-modern-kitchen.jpg',
    category: 'Kitchen',
    date: '2026-01-12',
    readTime: '7 min read',
  },
  {
    title: 'Open Concept Kitchen Remodel: Pros, Cons, and Costs in Seattle',
    slug: 'open-concept-kitchen-remodel',
    excerpt: 'Everything you need to know about removing walls, load-bearing considerations, permits, and costs for an open-concept kitchen in Seattle.',
    image: '/images/blog-kitchen-ideas.jpg',
    category: 'Kitchen',
    date: '2026-01-05',
    readTime: '8 min read',
  },
];
---

<BaseLayout
  title="Kitchen Remodeling Blog | Tips & Ideas | Best KB Remodeling"
  description="Expert kitchen remodeling tips, design ideas, and planning guides for Seattle homeowners. From cabinet styles to countertop comparisons and ROI analysis."
  canonical={`${SITE.url}/blog/category/kitchen/`}
  ogImage="/images/og/og-blog.png"
>
  <SchemaBreadcrumb items={breadcrumbs} />

  <!-- Hero -->
  <section class="bg-primary pt-32 pb-16">
    <Container>
      <div class="max-w-3xl" data-reveal>
        <p class="text-accent font-semibold uppercase tracking-wider text-sm mb-3">Kitchen Remodeling</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[family-name:var(--font-heading)] text-white mb-6">Kitchen Remodeling Blog</h1>
        <p class="text-lg text-white/80 leading-relaxed">
          Design inspiration, material comparisons, cost guides, and expert tips to help you plan the perfect kitchen remodel for your Seattle home.
        </p>
      </div>
    </Container>
  </section>

  <!-- Category Nav -->
  <section class="py-6 border-b border-border bg-white">
    <Container>
      <nav class="flex flex-wrap items-center gap-3">
        <a href="/blog/" class="text-sm font-medium text-muted hover:text-accent transition-colors">All Posts</a>
        <span class="text-border">|</span>
        <span class="text-sm font-bold text-accent">Kitchen</span>
        <span class="text-border">|</span>
        <a href="/blog/category/bathroom/" class="text-sm font-medium text-muted hover:text-accent transition-colors">Bathroom</a>
        <span class="text-border">|</span>
        <a href="/blog/category/tips/" class="text-sm font-medium text-muted hover:text-accent transition-colors">Tips</a>
      </nav>
    </Container>
  </section>

  <!-- Blog Grid -->
  <section class="py-20">
    <Container>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" data-reveal-stagger>
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}/`}
            class="group bg-white border border-border rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300"
          >
            <div class="aspect-[16/10] overflow-hidden relative">
              <picture>
                <source srcset={post.image.replace('.jpg', '.webp')} type="image/webp" />
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width="800"
                  height="500"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
              <span class="absolute top-4 left-4 bg-accent text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">
                {post.category}
              </span>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 text-sm text-muted mb-3">
                <time datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>
                <span>&middot;</span>
                <span>{post.readTime}</span>
              </div>
              <h2 class="text-lg font-[family-name:var(--font-heading)] text-primary mb-2 group-hover:text-accent transition-colors leading-snug">{post.title}</h2>
              <p class="text-body-text text-sm leading-relaxed">{post.excerpt}</p>
              <span class="inline-flex items-center gap-1.5 text-accent font-medium text-sm mt-4 group-hover:gap-2.5 transition-all">
                Read Article
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-light">
    <Container>
      <div class="text-center max-w-2xl mx-auto" data-reveal>
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">Ready to Remodel Your Kitchen?</h2>
        <p class="text-body-text text-lg mb-8">
          From initial design to final walkthrough, our team handles every detail of your kitchen remodel. Get a free estimate today.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="https://nexfield.pro/crm/book?u=137" target="_blank" rel="noopener noreferrer" variant="primary" size="lg">Get a Free Estimate</Button>
          <Button href="/services/kitchen-remodeling/" variant="outline" size="lg">Kitchen Remodeling Services</Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
