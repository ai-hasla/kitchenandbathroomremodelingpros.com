---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { SITE } from '@/lib/constants';

const breadcrumbs = [
  { label: 'Blog', href: '/blog/' },
  { label: 'Tips', href: '/blog/category/tips/' },
];

const posts = [
  {
    title: 'Seattle Remodeling Permits: What Homeowners Need to Know',
    slug: 'do-you-need-permit-remodel-seattle',
    excerpt: 'A practical guide to navigating the permit process for kitchen and bathroom remodels in Seattle, Bellevue, Kirkland, and surrounding cities.',
    image: '/images/blog-kitchen-remodel.jpg',
    category: 'Tips',
    date: '2025-12-18',
    readTime: '6 min read',
  },
  {
    title: 'Hardwood vs LVP Flooring: Which Is Best for Seattle Homes?',
    slug: 'hardwood-vs-lvp-flooring-seattle',
    excerpt: 'Compare durability, cost, and performance of hardwood and luxury vinyl plank flooring for Pacific Northwest climates.',
    image: '/images/blog-remodel-process.jpg',
    category: 'Tips',
    date: '2026-02-15',
    readTime: '8 min read',
  },
];
---

<BaseLayout
  title="Remodeling Tips & Guides Blog | Best KB Remodeling"
  description="Practical remodeling tips, permit guides, and material comparisons for Seattle homeowners. Expert advice to help you make informed decisions for your project."
  canonical={`${SITE.url}/blog/category/tips/`}
  ogImage="/images/og/og-blog.png"
>
  <SchemaBreadcrumb items={breadcrumbs} />

  <!-- Hero -->
  <section class="bg-primary pt-32 pb-16">
    <Container>
      <div class="max-w-3xl" data-reveal>
        <p class="text-accent font-semibold uppercase tracking-wider text-sm mb-3">Tips & Guides</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[family-name:var(--font-heading)] text-white mb-6">Remodeling Tips & Guides</h1>
        <p class="text-lg text-white/80 leading-relaxed">
          Permits, material comparisons, flooring options, and practical advice to help you navigate your remodeling project in Seattle.
        </p>
      </div>
    </Container>
  </section>

  <!-- Category Nav -->
  <section class="py-6 border-b border-border bg-white">
    <Container>
      <nav class="flex flex-wrap items-center gap-3">
        <a href="/blog/" class="text-sm font-medium text-muted hover:text-accent transition-colors">All Posts</a>
        <span class="text-border">|</span>
        <a href="/blog/category/kitchen/" class="text-sm font-medium text-muted hover:text-accent transition-colors">Kitchen</a>
        <span class="text-border">|</span>
        <a href="/blog/category/bathroom/" class="text-sm font-medium text-muted hover:text-accent transition-colors">Bathroom</a>
        <span class="text-border">|</span>
        <span class="text-sm font-bold text-accent">Tips</span>
      </nav>
    </Container>
  </section>

  <!-- Blog Grid -->
  <section class="py-20">
    <Container>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" data-reveal-stagger>
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}/`}
            class="group bg-white border border-border rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300"
          >
            <div class="aspect-[16/10] overflow-hidden relative">
              <picture>
                <source srcset={post.image.replace('.jpg', '.webp')} type="image/webp" />
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width="800"
                  height="500"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
              <span class="absolute top-4 left-4 bg-accent text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">
                {post.category}
              </span>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 text-sm text-muted mb-3">
                <time datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>
                <span>&middot;</span>
                <span>{post.readTime}</span>
              </div>
              <h2 class="text-lg font-[family-name:var(--font-heading)] text-primary mb-2 group-hover:text-accent transition-colors leading-snug">{post.title}</h2>
              <p class="text-body-text text-sm leading-relaxed">{post.excerpt}</p>
              <span class="inline-flex items-center gap-1.5 text-accent font-medium text-sm mt-4 group-hover:gap-2.5 transition-all">
                Read Article
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-light">
    <Container>
      <div class="text-center max-w-2xl mx-auto" data-reveal>
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">Have Questions About Your Project?</h2>
        <p class="text-body-text text-lg mb-8">
          Our team is happy to answer your remodeling questions. Schedule a free consultation and let us help you plan your next project.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="https://nexfield.pro/crm/book?u=137" target="_blank" rel="noopener noreferrer" variant="primary" size="lg">Get a Free Estimate</Button>
          <Button href="/blog/" variant="outline" size="lg">Browse All Articles</Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
