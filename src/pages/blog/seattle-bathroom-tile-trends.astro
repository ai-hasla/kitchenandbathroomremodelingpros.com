  author: { '@type': 'Organization', name: SITE.name },
  publisher: { '@type': 'Organization', name: SITE.name },
  datePublished: '2026-02-28',
  dateModified: '2026-02-28',
  image: '/images/blog-tile-trends.jpg',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What bathroom tile is most popular in Seattle in 2026?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Large format porcelain tiles (12x24 and 24x24) are the most popular bathroom tile choice in Seattle for 2026, followed by zellige (handmade Moroccan) tiles, matte subway tile variations, and natural stone like marble and travertine. Earthy tones, organic textures, and matte finishes dominate the Seattle market, reflecting the Pacific Northwest connection to nature.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does bathroom tile installation cost in Seattle?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Bathroom tile installation in Seattle costs $8-$25 per square foot for labor, depending on tile size, pattern complexity, and surface preparation. Material costs range from $2-$8/sq ft for porcelain, $5-$15/sq ft for natural stone, $10-$25/sq ft for zellige, and $8-$20/sq ft for cement tiles. A typical Seattle bathroom tile project (floors and shower) runs $3,000-$10,000 total for materials and installation.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is subway tile still in style for bathrooms in 2026?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, subway tile remains a timeless choice, but the trend has shifted from standard 3x6 white glossy subway tile to more interesting variations. Elongated formats (4x12, 2x10), handmade and zellige textures, vertical stacking patterns, and muted colors like sage, taupe, and soft blue are the current subway tile trends in Seattle bathrooms.',
      },
    },
    {
