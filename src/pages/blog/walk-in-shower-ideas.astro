const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: '12 Walk-In Shower Ideas That Transform Your Bathroom',
  description: 'Discover 12 stunning walk-in shower ideas for your bathroom remodel. From frameless glass enclosures to curbless designs, find the perfect shower upgrade for your Seattle home.',
  author: { '@type': 'Organization', name: SITE.name },
  publisher: { '@type': 'Organization', name: SITE.name },
  datePublished: '2026-01-20',
  dateModified: '2026-01-20',
  image: '/images/blog-walk-in-shower.jpg',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does a walk-in shower cost in Seattle?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A walk-in shower installation in Seattle typically costs $4,000-$8,000 for a basic design, $8,000-$15,000 for a mid-range custom shower with frameless glass, and $15,000-$25,000+ for a luxury walk-in shower with premium tile, multiple showerheads, and built-in features. Curbless designs add approximately $1,000-$3,000 due to the additional waterproofing and floor modifications required.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can you convert a bathtub to a walk-in shower?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, converting a bathtub to a walk-in shower is one of the most popular bathroom remodeling projects in Seattle. The conversion typically takes 5-10 days and involves removing the tub, reworking plumbing and waterproofing, installing new walls and flooring, and adding a glass enclosure. We recommend keeping at least one bathtub in the home for resale value.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the best tile for a walk-in shower?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Porcelain tile is the best overall choice for walk-in showers due to its low water absorption rate (less than 0.5%), durability, and wide range of styles. Natural stone like marble and travertine offers a luxury look but requires sealing. For shower floors, smaller mosaic tiles (2x2 inch or penny rounds) with more grout lines provide better traction and slip resistance.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do walk-in showers increase home value?',
      acceptedAnswer: {
