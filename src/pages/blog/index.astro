---

<BaseLayout
  title="Blog | Kitchen & Bathroom Remodeling Tips & Inspiration"
  description="Expert tips, design inspiration, and practical advice for kitchen and bathroom remodeling in Seattle. Guides, trends, and cost-saving strategies from our team."
  canonical={`${SITE.url}/blog/`}
  ogImage="/images/og/og-blog.png"
>
  <SchemaBreadcrumb items={breadcrumbs} />

  <!-- Hero -->
  <section class="bg-primary pt-32 pb-16">
    <Container>
      <div class="max-w-3xl" data-reveal>
        <p class="text-accent font-semibold uppercase tracking-wider text-sm mb-3">Tips & Inspiration</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[family-name:var(--font-heading)] text-white mb-6">Remodeling Blog</h1>
        <p class="text-lg text-white/80 leading-relaxed">
          Expert advice, design inspiration, and practical guides to help you plan and execute your dream kitchen or bathroom remodel.
        </p>
      </div>
    </Container>
  </section>

  <!-- Blog Grid -->
  <section class="py-20">
    <Container>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" data-reveal-stagger>
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}/`}
            class="group bg-white border border-border rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300"
          >
            <div class="aspect-[16/10] overflow-hidden relative">
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width="800"
                height="500"
                loading="lazy"
              />
              <span class="absolute top-4 left-4 bg-accent text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">
                {post.category}
              </span>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 text-sm text-muted mb-3">
                <time datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>
                <span>&middot;</span>
                <span>{post.readTime}</span>
              </div>
              <h2 class="text-lg font-[family-name:var(--font-heading)] text-primary mb-2 group-hover:text-accent transition-colors leading-snug">{post.title}</h2>
              <p class="text-body-text text-sm leading-relaxed">{post.excerpt}</p>
              <span class="inline-flex items-center gap-1.5 text-accent font-medium text-sm mt-4 group-hover:gap-2.5 transition-all">
                Read Article
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-light">
    <Container>
      <div class="text-center max-w-2xl mx-auto" data-reveal>
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">Ready to Start Planning?</h2>
        <p class="text-body-text text-lg mb-8">
          Whether you're in the research phase or ready to begin, we're here to help. Get a free estimate for your remodeling project.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="https://nexfield.pro/crm/book?u=137" target="_blank" rel="noopener noreferrer" variant="primary" size="lg">Get a Free Estimate</Button>
          <Button href="/cost-guides/" variant="outline" size="lg">View Cost Guides</Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
