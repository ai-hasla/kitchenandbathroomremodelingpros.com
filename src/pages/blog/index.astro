---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { SITE } from '@/lib/constants';

const breadcrumbs = [{ label: 'Blog', href: '/blog/' }];

const posts = [
  {
    title: '15 Kitchen Remodel Ideas for Seattle Homes in 2026',
    slug: 'kitchen-remodel-ideas-seattle',
    excerpt: 'From waterfall islands to two-tone cabinets, explore the top kitchen remodeling trends that are perfect for Pacific Northwest homes.',
    image: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?auto=format&fit=crop&w=800&q=80',
    category: 'Kitchen',
    date: '2026-02-20',
    readTime: '10 min read',
  },
  {
    title: '10 Bathroom Remodel Ideas That Add Value to Your Seattle Home',
    slug: 'bathroom-remodel-ideas-seattle',
    excerpt: 'Discover bathroom renovation ideas that not only look stunning but also boost your home\'s resale value in the competitive Seattle market.',
    image: 'https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?auto=format&fit=crop&w=800&q=80',
    category: 'Bathroom',
    date: '2026-02-12',
    readTime: '9 min read',
  },
  {
    title: 'How to Choose the Right Countertop Material for Your Kitchen',
    slug: 'quartz-vs-granite-countertops-seattle',
    excerpt: 'Quartz vs. granite vs. marble vs. butcher block: a comprehensive comparison to help you pick the perfect countertop for your lifestyle and budget.',
    image: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=800&q=80',
    category: 'Kitchen',
    date: '2026-01-28',
    readTime: '8 min read',
  },
  {
    title: 'The Complete Guide to Aging-in-Place Bathroom Design',
    slug: 'bathroom-remodel-ideas-seattle',
    excerpt: 'How to create a beautiful, accessible bathroom that keeps seniors safe and independent. ADA guidelines, design tips, and cost considerations.',
    image: 'https://images.unsplash.com/photo-1620626011761-996317b8d101?auto=format&fit=crop&w=800&q=80',
    category: 'Bathroom',
    date: '2026-01-15',
    readTime: '7 min read',
  },
  {
    title: 'Seattle Remodeling Permits: What Homeowners Need to Know',
    slug: 'do-you-need-permit-remodel-seattle',
    excerpt: 'A practical guide to navigating the permit process for kitchen and bathroom remodels in Seattle, Bellevue, Kirkland, and surrounding cities.',
    image: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=800&q=80',
    category: 'Tips',
    date: '2025-12-18',
    readTime: '6 min read',
  },
  {
    title: '2026 Kitchen Color Trends for Pacific Northwest Homes',
    slug: 'kitchen-remodel-ideas-seattle',
    excerpt: 'Earthy tones, deep greens, and warm neutrals are dominating PNW kitchens in 2026. See the colors that work best with Seattle\'s natural light.',
    image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=800&q=80',
    category: 'Design',
    date: '2025-12-05',
    readTime: '5 min read',
  },
];
---

<BaseLayout
  title="Blog | Kitchen & Bathroom Remodeling Tips & Inspiration"
  description="Expert tips, design inspiration, and practical advice for kitchen and bathroom remodeling in Seattle. Guides, trends, and cost-saving strategies from our team."
  canonical={`${SITE.url}/blog/`}
>
  <SchemaBreadcrumb items={breadcrumbs} />

  <!-- Hero -->
  <section class="bg-primary pt-32 pb-16">
    <Container>
      <div class="max-w-3xl" data-reveal>
        <p class="text-accent font-semibold uppercase tracking-wider text-sm mb-3">Tips & Inspiration</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[family-name:var(--font-heading)] text-white mb-6">Remodeling Blog</h1>
        <p class="text-lg text-white/80 leading-relaxed">
          Expert advice, design inspiration, and practical guides to help you plan and execute your dream kitchen or bathroom remodel.
        </p>
      </div>
    </Container>
  </section>

  <!-- Blog Grid -->
  <section class="py-20">
    <Container>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" data-reveal-stagger>
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}/`}
            class="group bg-white border border-border rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300"
          >
            <div class="aspect-[16/10] overflow-hidden relative">
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width="800"
                height="500"
                loading="lazy"
              />
              <span class="absolute top-4 left-4 bg-accent text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">
                {post.category}
              </span>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 text-sm text-muted mb-3">
                <time datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>
                <span>&middot;</span>
                <span>{post.readTime}</span>
              </div>
              <h2 class="text-lg font-[family-name:var(--font-heading)] text-primary mb-2 group-hover:text-accent transition-colors leading-snug">{post.title}</h2>
              <p class="text-body-text text-sm leading-relaxed">{post.excerpt}</p>
              <span class="inline-flex items-center gap-1.5 text-accent font-medium text-sm mt-4 group-hover:gap-2.5 transition-all">
                Read Article
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-light">
    <Container>
      <div class="text-center max-w-2xl mx-auto" data-reveal>
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">Ready to Start Planning?</h2>
        <p class="text-body-text text-lg mb-8">
          Whether you're in the research phase or ready to begin, we're here to help. Get a free estimate for your remodeling project.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/get-a-quote/" variant="primary" size="lg">Get a Free Estimate</Button>
          <Button href="/cost-guides/" variant="outline" size="lg">View Cost Guides</Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
