              <a href="/cost-guides/" class="inline-flex items-center justify-center gap-2 border border-white/30 text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">View Cost Guides</a>
            </div>
          </div>

          <!-- CTA -->
          <div class="bg-primary rounded-2xl p-8 text-center" data-reveal>
            <h2 class="text-2xl font-[family-name:var(--font-heading)] text-white mb-3">Ready to Choose Your Countertops?</h2>
            <p class="text-white/80 mb-6">Schedule a free consultation and we'll help you select the perfect countertop material for your kitchen and budget.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <Button href="https://nexfield.pro/crm/book?u=137" target="_blank" rel="noopener noreferrer" variant="primary" size="lg">Get a Free Estimate</Button>
              <Button href="/gallery/" variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-primary">View Our Gallery</Button>
            </div>
          </div>

        </article>

        <!-- Sidebar -->
        <aside class="lg:col-span-4 space-y-8" data-reveal="right">
          <div class="sticky top-24 space-y-8">
            
