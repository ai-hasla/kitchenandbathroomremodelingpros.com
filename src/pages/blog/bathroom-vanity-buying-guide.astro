const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Bathroom Vanity Buying Guide: Sizes, Styles & Installation Tips',
  description: 'Complete bathroom vanity buying guide covering sizes, single vs double vanities, floating vs freestanding, materials, storage options, and professional installation tips for Seattle homeowners.',
  author: { '@type': 'Organization', name: SITE.name },
  publisher: { '@type': 'Organization', name: SITE.name },
  datePublished: '2025-11-28',
  dateModified: '2025-11-28',
  image: '/images/blog-bathroom-vanity.jpg',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is the most popular bathroom vanity size?',
      acceptedAnswer: { '@type': 'Answer', text: 'The most popular vanity sizes are 30 inches and 36 inches wide for single vanities, and 60 inches and 72 inches wide for double vanities. For small Seattle bathrooms, 24-inch vanities are common and effective. The standard depth is 21-22 inches, though narrow-depth vanities (18 inches) are available for tight spaces like powder rooms.' },
    },
    {
      '@type': 'Question',
      name: 'Is a floating vanity or freestanding vanity better?',
      acceptedAnswer: { '@type': 'Answer', text: 'Floating (wall-mounted) vanities make small bathrooms look larger by exposing floor space, are easier to clean around, and create a modern aesthetic. Freestanding vanities offer more storage, are easier to install, and come in more traditional styles. For Seattle homes with small bathrooms, floating vanities are often the better choice for the visual space they create.' },
    },
    {
      '@type': 'Question',
      name: 'How much does it cost to install a bathroom vanity in Seattle?',
      acceptedAnswer: { '@type': 'Answer', text: 'Professional vanity installation in Seattle costs $300 to $800 for labor, not including the vanity itself. A basic vanity with countertop costs $400 to $1,500. Mid-range options run $1,500 to $3,500. High-end custom vanities cost $3,500 to $8,000 or more. Total installed cost including plumbing connections ranges from $800 to $9,000 depending on quality and complexity.' },
