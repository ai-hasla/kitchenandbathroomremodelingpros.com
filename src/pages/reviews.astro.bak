---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { SITE } from '@/lib/constants';

const breadcrumbs = [{ label: 'Reviews', href: '/reviews/' }];

/**
 * IMPORTANT: The reviews below are EXAMPLE placeholders.
 * Replace these with real customer reviews before publishing.
 * Each review should have written permission from the customer.
 */
const reviews = [
  {
    name: 'Jennifer T.',
    rating: 5,
    neighborhood: 'Ballard, Seattle',
    projectType: 'Kitchen Remodel',
    text: 'Our 1940s Craftsman kitchen was completely transformed. Custom shaker cabinets, quartz countertops, and a herringbone backsplash — all completed on time and within budget. The team was professional from consultation to final walkthrough.',
  },
  {
    name: 'Robert N.',
    rating: 5,
    neighborhood: 'Bellevue',
    projectType: 'Bathroom Remodel',
    text: 'They turned our dated master bathroom into a spa-like retreat with a walk-in shower, heated floors, and a floating vanity. The tile work is immaculate and the crew cleaned up every single day. Outstanding work from start to finish.',
  },
  {
    name: 'Lisa G.',
    rating: 5,
    neighborhood: 'Kirkland',
    projectType: 'Kitchen & Bathroom',
    text: 'We had both our kitchen and guest bathroom remodeled. New cabinets, granite countertops, subway tile backsplash in the kitchen, and a full bathroom update with new tub and vanity. Communication was excellent throughout the entire project.',
  },
  {
    name: 'Amanda P.',
    rating: 5,
    neighborhood: 'Redmond',
    projectType: 'Kitchen Remodel',
    text: 'As a first-time homeowner, I was nervous about a major remodel, but the team made it stress-free. My new kitchen has two-tone cabinets, a waterfall quartz island, and pendant lighting. Friends cannot believe the transformation.',
  },
  {
    name: 'David L.',
    rating: 5,
    neighborhood: 'Mercer Island',
    projectType: 'Shower Remodel',
    text: 'We needed our leaking shower completely replaced. They installed a frameless glass walk-in with large format tiles and a rain showerhead. They also found and repaired hidden water damage. Honest, skilled, and professional.',
  },
  {
    name: 'Michael T.',
    rating: 4,
    neighborhood: 'Renton',
    projectType: 'Bathroom Remodel',
    text: 'Very pleased with our bathroom remodel — the vanity and tile work are excellent. Project ran about a week longer than estimated due to a back-ordered faucet, but they kept us informed and the finished product is beautiful.',
  },
  {
    name: 'Karen W.',
    rating: 5,
    neighborhood: 'Sammamish',
    projectType: 'Cabinet Refacing',
    text: 'Rather than spending $50K+ on new cabinets, they refaced our existing ones with maple doors and soft-close hardware. The kitchen looks completely brand new for a fraction of the cost. The craftsmanship is remarkable.',
  },
  {
    name: 'Rachel K.',
    rating: 5,
    neighborhood: 'Capitol Hill, Seattle',
    projectType: 'Condo Bathroom Remodel',
    text: 'My condo bathroom was completely gutted and rebuilt with a tile shower bench, new vanity, and hex tile flooring. They handled all the HOA coordination seamlessly. The bathroom is now the most beautiful room in my home.',
  },
];

const averageRating = SITE.reviews.rating;
const totalReviews = SITE.reviews.count;

const aggregateSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE.name,
  url: SITE.url,
  telephone: SITE.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    postalCode: SITE.address.zip,
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: averageRating,
    reviewCount: totalReviews,
    bestRating: 5,
    worstRating: 1,
  },
  review: reviews.map((r) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.name },
    reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5 },
    reviewBody: r.text,
  })),
};
---

<BaseLayout
  title="Customer Reviews | Kitchen & Bathroom Remodeling Seattle"
  description="Read customer reviews of Best Kitchen and Bathroom Remodeling in Seattle. 4.9-star rating across 230+ reviews. See why homeowners across Seattle, Bellevue, and Kirkland trust our team."
  canonical={`${SITE.url}/reviews/`}
  ogImage="/images/og/og-reviews.png"
>
  <SchemaBreadcrumb items={breadcrumbs} />
  <script type="application/ld+json" set:html={JSON.stringify(aggregateSchema)} />

  <!-- Hero -->
  <section class="bg-primary pt-32 pb-16">
    <Container>
      <div class="max-w-3xl" data-reveal>
        <p class="text-accent font-semibold uppercase tracking-wider text-sm mb-3">Testimonials</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[family-name:var(--font-heading)] text-white mb-6">Customer Reviews</h1>
        <p class="text-lg text-white/80 leading-relaxed">
          Don't just take our word for it. Read what Seattle homeowners have to say about their kitchen and bathroom remodeling experience with our team.
        </p>
      </div>
    </Container>
  </section>

  <!-- Aggregate Rating Bar -->
  <section class="py-12 bg-accent-light border-b border-border">
    <Container>
      <div class="flex flex-col md:flex-row items-center justify-between gap-6" data-reveal>
        <div class="flex items-center gap-6">
          <div class="text-center">
            <p class="text-5xl font-bold font-[family-name:var(--font-heading)] text-primary">{averageRating}</p>
            <div class="flex gap-0.5 mt-1">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
          </div>
          <div>
            <p class="text-lg font-semibold text-primary">Based on {totalReviews} verified reviews</p>
            <p class="text-body-text text-sm">Collected from Google, Yelp, and Houzz</p>
          </div>
        </div>
        <a
          href={SITE.social.google}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-white border border-border px-5 py-3 rounded-lg hover:shadow-md transition-shadow font-medium text-primary"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Review Us on Google
        </a>
      </div>
    </Container>
  </section>

  <!-- Google Reviews Placeholder -->
  <section class="py-12 bg-white border-b border-border">
    <Container>
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <h2 class="text-2xl font-[family-name:var(--font-heading)] text-primary mb-4">Find Us on Review Platforms</h2>
        <p class="text-body-text mb-6">Read more reviews and share your experience on the platforms below.</p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href={SITE.social.google} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border border-border rounded-lg px-5 py-3 hover:shadow-md transition-shadow text-sm font-medium text-primary">
            <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Google Reviews
          </a>
          <a href={SITE.social.yelp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border border-border rounded-lg px-5 py-3 hover:shadow-md transition-shadow text-sm font-medium text-primary">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="#D32323"><path d="M12.271 11.985l-3.326-4.63c-.357-.497-.903-.67-1.412-.447-.51.223-.773.716-.682 1.276l1.086 6.664c.091.56.498.935.998.935.11 0 .223-.017.336-.054l3-1.003c.52-.174.85-.635.85-1.19 0-.556-.33-1.078-.85-1.251v-.3zm-5.106 3.312l-1.542 4.79c-.175.544.03 1.088.526 1.395.256.158.537.234.812.234.244 0 .483-.06.698-.178l3.623-2.006c.444-.246.68-.703.616-1.19-.064-.487-.392-.87-.854-1l-3.093-1.032c-.31-.103-.547-.075-.786.987zm8.01-4.54l4.088-2.553c.463-.29.657-.817.498-1.358-.159-.541-.604-.873-1.146-.854l-4.792.167c-.542.019-.972.39-1.086.937-.115.547.126 1.074.611 1.336l1.352.704c.157.082.318.121.475.121.221 0 .438-.087.614-.255l-.614-.245z"/></svg>
            Yelp Reviews
          </a>
          <a href={SITE.social.houzz} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border border-border rounded-lg px-5 py-3 hover:shadow-md transition-shadow text-sm font-medium text-primary">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="#4DBC15"><rect x="6" y="3" width="5" height="9" rx="0.5"/><rect x="13" y="8" width="5" height="9" rx="0.5"/><rect x="6" y="14" width="5" height="7" rx="0.5"/></svg>
            Houzz Reviews
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- Reviews Grid -->
  <section class="py-20">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-4" data-reveal>
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">What Our Clients Say</h2>
      </div>
      <!-- Example notice -->
      <p class="text-center text-xs text-muted mb-12 italic" data-reveal>
        Note: The reviews below are example testimonials. They will be replaced with verified customer reviews.
      </p>

      <div class="grid md:grid-cols-2 gap-8" data-reveal-stagger>
        {reviews.map((review) => (
          <div class="bg-white border border-border rounded-2xl p-8 hover:shadow-lg transition-shadow">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-semibold text-primary">{review.name}</h3>
                <p class="text-sm text-muted">{review.neighborhood} &middot; {review.projectType}</p>
              </div>
            </div>
            <div class="flex gap-0.5 mb-4">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class={`w-4 h-4 ${i < review.rating ? 'text-accent' : 'text-border'}`} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <p class="text-body-text leading-relaxed text-sm">{review.text}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Read More CTA -->
  <section class="py-16 bg-light">
    <Container>
      <div class="text-center max-w-2xl mx-auto" data-reveal>
        <h2 class="text-2xl md:text-3xl font-[family-name:var(--font-heading)] text-primary mb-4">Read More Reviews</h2>
        <p class="text-body-text mb-8">
          Want to see more? Check out our full reviews on Google and Yelp to hear directly from homeowners across Seattle, Bellevue, Kirkland, Redmond, and beyond.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={SITE.social.google} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-white border border-border rounded-lg px-6 py-3 hover:shadow-md transition-shadow font-medium text-primary">
            <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Read Google Reviews
          </a>
          <a href={SITE.social.yelp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-white border border-border rounded-lg px-6 py-3 hover:shadow-md transition-shadow font-medium text-primary">
            Read Yelp Reviews
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary">
    <Container>
      <div class="text-center max-w-2xl mx-auto" data-reveal>
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-white mb-4">Ready to Start Your Project?</h2>
        <p class="text-white/80 text-lg mb-8">
          Join our growing list of happy homeowners. Get a free, no-obligation estimate for your kitchen or bathroom remodel today.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="https://nexfield.pro/crm/book?u=137" target="_blank" rel="noopener noreferrer" variant="primary" size="lg">Get a Free Estimate</Button>
          <Button href={`tel:${SITE.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-primary">Call {SITE.phone}</Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
