---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { SITE, LOCATIONS_TIER1, LOCATIONS_TIER2, ALL_LOCATIONS } from '@/lib/constants';
import { locationData } from '@/data/locations/location-data';
---

<BaseLayout
  title="Areas We Serve | Kitchen & Bathroom Remodeling Seattle Area"
  description="Kitchen and bathroom remodeling across the greater Seattle and Puget Sound area. Serving 28 cities including Seattle, Bellevue, Kirkland, Tacoma, Everett & more. Free estimates."
>
  <SchemaBreadcrumb
    items={[
      { label: 'Areas We Serve', href: '/areas-served/' },
    ]}
  />

  <!-- Hero Section -->
  <section class="bg-primary pt-32 pb-16">
    <Container>
      <div class="text-center max-w-3xl mx-auto" data-reveal>
        <h1 class="text-4xl lg:text-5xl font-[family-name:var(--font-heading)] text-white leading-tight mb-6">
          Areas We Serve in the Greater Seattle Area
        </h1>
        <p class="text-white/80 text-lg leading-relaxed">
          From the Craftsman bungalows of Seattle to the luxury estates of Sammamish,
          our expert remodeling team serves homeowners across 28 cities in King, Snohomish,
          and Pierce Counties. Wherever you call home in the Puget Sound region, we bring
          the same commitment to quality craftsmanship and transparent pricing.
        </p>
      </div>
    </Container>
  </section>

  <!-- Map Section -->
  <section class="py-12 lg:py-16 bg-light">
    <Container>
      <div class="max-w-4xl mx-auto" data-reveal>
        <h2 class="text-2xl lg:text-3xl font-[family-name:var(--font-heading)] text-dark-text text-center mb-8">
          Our Service Area
        </h2>
        <div class="rounded-xl overflow-hidden shadow-lg aspect-video bg-muted/20">
          <!-- Google Maps Embed Placeholder — replace src with your actual API key embed URL -->
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d172860.26055503384!2d-122.33207!3d47.6062!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Best Kitchen and Bathroom Remodeling service area map — Greater Seattle and Puget Sound region"
          ></iframe>
        </div>
        <p class="text-center text-muted text-sm mt-4">
          Serving homeowners in Everett, Tacoma and across the Eastside
        </p>
      </div>
    </Container>
  </section>

  <!-- Tier 1 Cities -->
  <section class="py-16 lg:py-24">
    <Container>
      <div class="text-center mb-12" data-reveal>
        <h2 class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-dark-text leading-tight mb-4">
          Primary Service Areas
        </h2>
        <p class="text-muted text-lg max-w-2xl mx-auto">
          These are the communities where we complete the most projects. We know the local
          building codes, popular home styles, and neighborhood character inside and out.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6" data-reveal>
        {LOCATIONS_TIER1.map((location) => {
          const data = locationData[location.slug];
          return (
            <a
              href={`/areas-served/${location.slug}/`}
              class="group bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 p-6 flex flex-col"
            >
              <div class="flex items-start justify-between mb-3">
                <h3 class="text-lg font-bold text-dark-text group-hover:text-accent transition-colors">
                  {location.city}
                </h3>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 text-muted/40 group-hover:text-accent group-hover:translate-x-0.5 transition-all duration-200 flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
              <p class="text-sm text-muted mb-3">
                {location.county} County
              </p>
            </a>
          );
        })}
      </div>
    </Container>
  </section>

  <!-- Tier 2 Cities -->
  <section class="py-16 lg:py-24 bg-light">
    <Container>
      <div class="text-center mb-12" data-reveal>
        <h2 class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-dark-text leading-tight mb-4">
          Additional Communities We Serve
        </h2>
        <p class="text-muted text-lg max-w-2xl mx-auto">
          Our service area extends across the Puget Sound region. We bring the same
          expertise and dedication to every community we work in.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4" data-reveal>
        {LOCATIONS_TIER2.map((location) => (
          <a
            href={`/areas-served/${location.slug}/`}
            class="group bg-white rounded-lg border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 px-4 py-3 flex items-center justify-between gap-2"
          >
            <div>
              <span class="text-dark-text font-medium text-sm group-hover:text-accent transition-colors block">
                {location.city}
              </span>
              <span class="text-muted text-xs">{location.county} Co.</span>
            </div>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 text-muted/30 group-hover:text-accent group-hover:translate-x-0.5 transition-all duration-200 flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- Why Local Matters -->
  <section class="py-16 lg:py-24">
    <Container>
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <h2 class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-dark-text leading-tight mb-6">
          Why Local Expertise Matters
        </h2>
        <p class="text-muted text-lg leading-relaxed mb-8">
          Every city in the Puget Sound region has its own building codes, permit requirements,
          architectural styles, and homeowner expectations. Our team has completed projects in
          every community we serve, and we understand the unique considerations that come with
          remodeling a 1920s Craftsman in Seattle versus updating a 2005 builder-grade home in
          Sammamish. From navigating local permit offices to selecting materials that suit your
          home's character, we bring genuine local knowledge to every project.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-left">
          <div class="bg-light rounded-xl p-6">
            <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            </div>
            <h3 class="font-bold text-dark-text mb-2">Licensed & Permitted</h3>
            <p class="text-sm text-muted">We handle all local permits and inspections, ensuring your project is fully compliant with city and county codes.</p>
          </div>
          <div class="bg-light rounded-xl p-6">
            <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-dark-text mb-2">Truly Local</h3>
            <p class="text-sm text-muted">Based in Seattle, we know the neighborhoods, housing styles, and homeowner expectations across the Puget Sound region.</p>
          </div>
          <div class="bg-light rounded-xl p-6">
            <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
              </svg>
            </div>
            <h3 class="font-bold text-dark-text mb-2">Proven Results</h3>
            <p class="text-sm text-muted">Over {SITE.reviews.count} five-star reviews from homeowners across the region who trust our quality and professionalism.</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- CTA Section -->
  <section class="bg-accent py-16 lg:py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
    <Container class="relative z-10">
      <div class="text-center max-w-3xl mx-auto" data-reveal>
        <h2 class="text-3xl lg:text-5xl font-[family-name:var(--font-heading)] text-white mb-6">
          Ready to Start Your Remodel?
        </h2>
        <p class="text-white/90 text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
          No matter which Puget Sound community you call home, we offer free in-home
          consultations with detailed estimates. No obligation, no pressure.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
          <Button
            variant="primary"
            size="lg"
            href="/contact/"
            class="bg-white text-accent hover:bg-white/90 shadow-lg shadow-black/10"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
            Schedule Free Consultation
          </Button>
          <Button
            variant="outline"
            size="lg"
            href={`tel:${SITE.phoneRaw}`}
            class="border-white text-white hover:bg-white/10 border-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            Call {SITE.phone}
          </Button>
        </div>
        <p class="text-sm text-white/70">
          &#9733; Licensed, Bonded & Insured &bull; 15+ Years Experience &bull; 500+ Projects Completed
        </p>
      </div>
    </Container>
  </section>
</BaseLayout>
