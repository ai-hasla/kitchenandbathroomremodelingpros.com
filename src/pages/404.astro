---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { SITE } from '@/lib/constants';

const breadcrumbs = [{ label: '404 - Page Not Found', href: '/404/' }];

const popularServices = [
  { title: 'Kitchen Remodeling', href: '/services/kitchen-remodeling/', desc: 'Complete kitchen transformations' },
  { title: 'Bathroom Remodeling', href: '/services/bathroom-remodeling/', desc: 'Stunning bathroom renovations' },
  { title: 'Cabinet Refacing', href: '/services/cabinet-refacing/', desc: 'Refresh cabinets affordably' },
  { title: 'Countertop Installation', href: '/services/countertop-installation/', desc: 'Quartz, granite & marble' },
  { title: 'Shower Remodeling', href: '/services/shower-remodeling/', desc: 'Custom walk-in showers' },
  { title: 'Tile Installation', href: '/services/tile-installation/', desc: 'Floors, walls & backsplashes' },
];

const quickLinks = [
  { title: 'Cost Guides', href: '/cost-guides/', desc: 'Transparent pricing info' },
  { title: 'Project Gallery', href: '/gallery/', desc: 'See our completed projects' },
  { title: 'Reviews', href: '/reviews/', desc: '4.9\u2605 from 250+ homeowners' },
  { title: 'Blog', href: '/blog/', desc: 'Tips & remodeling guides' },
  { title: 'Areas We Serve', href: '/areas-served/', desc: 'Seattle & Puget Sound area' },
  { title: 'FAQ', href: '/faq/', desc: 'Common questions answered' },
];
---

<BaseLayout
  title="Page Not Found | Best Kitchen and Bathroom Remodeling"
  description="The page you're looking for doesn't exist. Browse our kitchen and bathroom remodeling services in Seattle."
  noindex={true}
  showSchema={false}
>
  <SchemaBreadcrumb items={breadcrumbs} />

  <section class="min-h-[70vh] bg-light pt-32 pb-20">
    <Container class="max-w-5xl">
      <!-- Header -->
      <div class="text-center mb-12">
        <p class="text-9xl font-[family-name:var(--font-heading)] text-accent/20 mb-2 select-none">404</p>
        <h1 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-dark-text mb-4">
          Oops! This Page Doesn't Exist
        </h1>
        <p class="text-lg text-muted mb-8 max-w-xl mx-auto">
          The page you're looking for may have been moved or removed. But we're still here to help you plan your dream remodel!
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button href="/" variant="primary" size="lg">
            Back to Home
          </Button>
          <Button href="/services/" variant="outline" size="lg">
            Browse Services
          </Button>
          <Button href="/contact/" variant="outline" size="lg">
            Contact Us
          </Button>
        </div>
      </div>

      <!-- Search Suggestion -->
      <div class="text-center mb-12 p-6 bg-white rounded-2xl border border-border max-w-2xl mx-auto">
        <p class="text-muted mb-2">Looking for something specific? Try one of these:</p>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="/cost-guides/kitchen-remodel-cost-seattle/" class="text-sm px-3 py-1.5 bg-light rounded-full text-accent hover:bg-accent hover:text-white transition-colors">Kitchen remodel cost</a>
          <a href="/cost-guides/bathroom-remodel-cost-seattle/" class="text-sm px-3 py-1.5 bg-light rounded-full text-accent hover:bg-accent hover:text-white transition-colors">Bathroom remodel cost</a>
          <a href="/blog/kitchen-remodel-ideas-seattle/" class="text-sm px-3 py-1.5 bg-light rounded-full text-accent hover:bg-accent hover:text-white transition-colors">Remodel ideas</a>
          <a href="/areas-served/" class="text-sm px-3 py-1.5 bg-light rounded-full text-accent hover:bg-accent hover:text-white transition-colors">Areas we serve</a>
          <a href="/sitemap-html/" class="text-sm px-3 py-1.5 bg-light rounded-full text-accent hover:bg-accent hover:text-white transition-colors">Full sitemap</a>
        </div>
      </div>

      <!-- Popular Services -->
      <div class="mb-12">
        <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-dark-text mb-6 text-center">Our Most Popular Services</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {popularServices.map((item) => (
            <a href={item.href} class="p-4 bg-white rounded-xl border border-border hover:border-accent hover:shadow-md transition-all group">
              <h3 class="font-semibold text-dark-text group-hover:text-accent transition-colors">{item.title}</h3>
              <p class="text-sm text-muted mt-1">{item.desc}</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div class="mb-12">
        <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-dark-text mb-6 text-center">Helpful Resources</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {quickLinks.map((item) => (
            <a href={item.href} class="p-4 bg-white rounded-xl border border-border hover:border-accent hover:shadow-md transition-all group">
              <h3 class="font-semibold text-dark-text group-hover:text-accent transition-colors">{item.title}</h3>
              <p class="text-sm text-muted mt-1">{item.desc}</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Contact -->
      <div class="p-6 bg-primary rounded-2xl text-white text-center">
        <p class="text-lg font-semibold mb-2">Need help? We're available 24/7</p>
        <a href={`tel:${SITE.phoneRaw}`} class="text-accent text-2xl font-bold hover:text-white transition-colors">{SITE.phone}</a>
        <p class="text-white/70 text-sm mt-2">
          Or <a href="/contact/" class="text-accent hover:text-white underline transition-colors">send us a message</a> &mdash;
          <a href="https://nexfield.pro/crm/book?u=137" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-white underline transition-colors">Get a Free Estimate</a>
        </p>
      </div>
    </Container>
  </section>
</BaseLayout>
