---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { SITE } from '@/lib/constants';

const breadcrumbs = [{ label: 'Contact Us', href: '/contact/' }];

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Kitchen & Bathroom Remodeling Pros',
  description: 'Get in touch with Seattle\'s top-rated kitchen and bathroom remodeling company. Call, email, or fill out our contact form for a free consultation.',
  url: `${SITE.url}/contact/`,
  mainEntity: {
    '@type': 'LocalBusiness',
    name: SITE.name,
    telephone: SITE.phone,
    email: SITE.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: SITE.address.street,
      addressLocality: SITE.address.city,
      addressRegion: SITE.address.state,
      postalCode: SITE.address.zip,
    },
  },
};
---

<BaseLayout
  title="Contact Us | Kitchen & Bathroom Remodeling Seattle"
  description="Contact Kitchen & Bathroom Remodeling Pros in Seattle. Call (206) 555-0123, email us, or fill out our form for a free consultation. Mon-Fri 8AM-6PM, Sat 9AM-4PM."
  canonical={`${SITE.url}/contact/`}
>
  <SchemaBreadcrumb items={breadcrumbs} />
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <!-- Hero -->
  <section class="bg-primary pt-32 pb-16">
    <Container>
      <div class="max-w-3xl" data-reveal>
        <p class="text-accent font-semibold uppercase tracking-wider text-sm mb-3">Get in Touch</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[family-name:var(--font-heading)] text-white mb-6">Contact Us</h1>
        <p class="text-lg text-white/80 leading-relaxed">
          Have a question or ready to start your remodeling project? We'd love to hear from you. Reach out by phone, email, or fill out the form below.
        </p>
      </div>
    </Container>
  </section>

  <!-- Contact Content -->
  <section class="py-20">
    <Container>
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- Contact Form -->
        <div class="lg:col-span-3" data-reveal>
          <h2 class="text-2xl font-[family-name:var(--font-heading)] text-primary mb-6">Send Us a Message</h2>
          <!--
            FORM ENDPOINT: This form currently uses client-side handling only.
            To receive submissions, replace with one of these services:
            - Formspree: <form action="https://formspree.io/f/YOUR_ID" method="POST">
            - Netlify Forms: <form name="contact" method="POST" data-netlify="true">
            - Basin: <form action="https://usebasin.com/f/YOUR_ID" method="POST">
          -->
          <form id="contact-form" class="space-y-6">
            <!-- Honeypot field for spam protection (hidden from real users) -->
            <div class="hidden" aria-hidden="true">
              <label for="website">Website</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>
            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-primary mb-2">Full Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="John Smith"
                  class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-primary mb-2">Email Address *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="john@example.com"
                  class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label for="phone" class="block text-sm font-medium text-primary mb-2">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="(206) 555-0000"
                  class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors"
                />
              </div>
              <div>
                <label for="project-type" class="block text-sm font-medium text-primary mb-2">Project Type *</label>
                <select
                  id="project-type"
                  name="project_type"
                  required
                  class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors bg-white"
                >
                  <option value="">Select a project type</option>
                  <option value="kitchen">Kitchen Remodel</option>
                  <option value="bathroom">Bathroom Remodel</option>
                  <option value="both">Kitchen & Bathroom</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>

            <div>
              <label for="timeline" class="block text-sm font-medium text-primary mb-2">When are you looking to start?</label>
              <select
                id="timeline"
                name="timeline"
                class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors bg-white"
              >
                <option value="">Select a timeline</option>
                <option value="asap">As soon as possible</option>
                <option value="1-3months">1-3 months</option>
                <option value="3-6months">3-6 months</option>
                <option value="6-12months">6-12 months</option>
                <option value="just-exploring">Just exploring options</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-primary mb-2">Message *</label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Tell us about your project — what you're looking to change, any ideas you have, or questions you'd like answered."
                class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors resize-y"
              ></textarea>
            </div>

            <Button type="submit" variant="primary" size="lg" class="w-full sm:w-auto">Send Message</Button>
          </form>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-2" data-reveal="right">
          <div class="bg-light rounded-2xl p-8 space-y-8">
            <div>
              <h3 class="text-lg font-[family-name:var(--font-heading)] text-primary mb-4">Contact Information</h3>
              <div class="space-y-4">
                <a href={`tel:${SITE.phoneRaw}`} class="flex items-start gap-3 group">
                  <div class="w-10 h-10 bg-accent-light rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                  </div>
                  <div>
                    <p class="text-sm text-muted">Phone</p>
                    <p class="font-semibold text-primary group-hover:text-accent transition-colors">{SITE.phone}</p>
                  </div>
                </a>
                <a href={`mailto:${SITE.email}`} class="flex items-start gap-3 group">
                  <div class="w-10 h-10 bg-accent-light rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                  </div>
                  <div>
                    <p class="text-sm text-muted">Email</p>
                    <p class="font-semibold text-primary group-hover:text-accent transition-colors text-sm">{SITE.email}</p>
                  </div>
                </a>
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 bg-accent-light rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  </div>
                  <div>
                    <p class="text-sm text-muted">Address</p>
                    <p class="font-semibold text-primary">{SITE.address.full}</p>
                  </div>
                </div>
              </div>
            </div>

            <div>
              <h3 class="text-lg font-[family-name:var(--font-heading)] text-primary mb-3">Business Hours</h3>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span class="text-body-text">Monday - Friday</span>
                  <span class="font-medium text-primary">8:00 AM - 6:00 PM</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-body-text">Saturday</span>
                  <span class="font-medium text-primary">9:00 AM - 4:00 PM</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-body-text">Sunday</span>
                  <span class="font-medium text-primary">Closed</span>
                </div>
              </div>
            </div>

            <div>
              <h3 class="text-lg font-[family-name:var(--font-heading)] text-primary mb-3">Follow Us</h3>
              <div class="flex gap-3">
                <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white border border-border rounded-lg flex items-center justify-center hover:bg-accent hover:text-white hover:border-accent transition-colors" aria-label="Facebook">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white border border-border rounded-lg flex items-center justify-center hover:bg-accent hover:text-white hover:border-accent transition-colors" aria-label="Instagram">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
                <a href={SITE.social.houzz} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white border border-border rounded-lg flex items-center justify-center hover:bg-accent hover:text-white hover:border-accent transition-colors" aria-label="Houzz">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.5 3.5v5.8H6.3V24h5.5V12.5h5.9V24h5.5V3.5z"/></svg>
                </a>
                <a href={SITE.social.yelp} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white border border-border rounded-lg flex items-center justify-center hover:bg-accent hover:text-white hover:border-accent transition-colors" aria-label="Yelp">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.16 12.594l-4.995 1.433c-.96.276-1.74-.8-1.176-1.63l2.905-4.308a1.072 1.072 0 011.596-.206l2.042 1.726c.68.575.42 1.593-.263 1.834zm-3.327 5.576l-.755-5.158c-.143-.98 1.085-1.539 1.737-.79l3.376 3.864c.487.557.126 1.46-.618 1.526l-2.621.222c-.474.04-.902-.278-1.027-.734zM11.124 18.77l2.023-4.77c.39-.918 1.768-.602 1.727.397l-.213 5.148c-.03.707-.78 1.143-1.394.81l-2.021-1.097c-.437-.238-.527-.828-.213-1.245zM8.78 9.35l4.91 1.71c.94.33.89 1.654-.07 1.908l-4.98 1.32c-.692.182-1.33-.42-1.166-1.1l.85-3.03c.127-.455.565-.742 1.025-.688zm.5-3.896l1.25 5.08c.24.97-1.01 1.59-1.67.828L5.5 7.38c-.5-.568-.15-1.49.6-1.54l2.6-.18c.47-.03.9.28 1.03.73z"/></svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Google Maps -->
          <div class="mt-8 rounded-2xl overflow-hidden shadow-lg border border-border" data-reveal>
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2689.7!2d-122.3321!3d47.6062!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDfCsDM2JzIyLjMiTiAxMjLCsDE5JzU1LjYiVw!5e0!3m2!1sen!2sus!4v1234567890"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Kitchen & Bathroom Remodeling Pros location on Google Maps"
            ></iframe>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      if (!form) return;

      form.addEventListener('submit', (e: Event) => {
        e.preventDefault();

        // Honeypot check — if filled, silently reject (bot submission)
        const honeypot = (form.querySelector('[name="website"]') as HTMLInputElement)?.value;
        if (honeypot) return;

        // Validate required fields
        const name = (form.querySelector('[name="name"]') as HTMLInputElement)?.value.trim();
        const email = (form.querySelector('[name="email"]') as HTMLInputElement)?.value.trim();
        const projectType = (form.querySelector('[name="project_type"]') as HTMLSelectElement)?.value;
        const message = (form.querySelector('[name="message"]') as HTMLTextAreaElement)?.value.trim();

        if (!name || !email || !projectType || !message) {
          alert('Please fill in all required fields.');
          return;
        }

        // Basic email validation
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(email)) {
          alert('Please enter a valid email address.');
          return;
        }

        // Replace form with success message
        const formContainer = form.parentElement;
        if (formContainer) {
          formContainer.innerHTML = `
            <div class="text-center py-12">
              <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h2 class="text-2xl font-bold text-primary mb-3">Thank you!</h2>
              <p class="text-lg text-body-text">We'll contact you within 24 hours.</p>
            </div>
          `;
        }
      });
    });
  </script>
</BaseLayout>
