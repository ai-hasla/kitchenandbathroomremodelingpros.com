---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroHome from '@/components/sections/HeroHome.astro';
import TrustBar from '@/components/sections/TrustBar.astro';
import ServicesOverview from '@/components/sections/ServicesOverview.astro';
import BeforeAfterShowcase from '@/components/sections/BeforeAfterShowcase.astro';
import WhyChooseUs from '@/components/sections/WhyChooseUs.astro';
import GuaranteeSection from '@/components/sections/GuaranteeSection.astro';
import FeaturedProjects from '@/components/sections/FeaturedProjects.astro';
import CostGuideTeaser from '@/components/sections/CostGuideTeaser.astro';
import AreasServed from '@/components/sections/AreasServed.astro';
import Testimonials from '@/components/sections/Testimonials.astro';
import ProcessSteps from '@/components/sections/ProcessSteps.astro';
import RecentWorkBanner from '@/components/sections/RecentWorkBanner.astro';
import BlogPreview from '@/components/sections/BlogPreview.astro';
import FinalCTA from '@/components/sections/FinalCTA.astro';
import SchemaOrganization from '@/components/seo/SchemaOrganization.astro';
import SchemaProduct from '@/components/seo/SchemaProduct.astro';
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro';
import SchemaHowTo from '@/components/seo/SchemaHowTo.astro';

const howToSteps = [
  {
    name: 'Schedule a Free In-Home Consultation',
    text: 'Contact us to schedule a complimentary in-home consultation. Our design expert will visit your home, discuss your vision, assess the space, and answer all your questions about the remodeling process.',
  },
  {
    name: 'Review Your Custom Design and Estimate',
    text: 'We create a detailed design plan and transparent cost estimate tailored to your project. Review 3D renderings, material options, and a complete breakdown of costs with no hidden fees.',
  },
  {
    name: 'We Handle Permits and Material Selection',
    text: 'Our team manages all necessary permits with the City of Seattle or your local jurisdiction. Visit our showroom to select materials including countertops, cabinetry, tile, and fixtures.',
  },
  {
    name: 'Professional Installation by Our Expert Team',
    text: 'Our licensed and insured craftsmen begin your remodel with meticulous attention to detail. We maintain a clean worksite, communicate progress daily, and stay on schedule.',
  },
  {
    name: 'Final Walkthrough and 5-Year Warranty Activation',
    text: 'Walk through your completed project with our project manager. We ensure every detail meets your expectations before activating your comprehensive 5-year craftsmanship warranty.',
  },
];

const faqItems = [
  {
    question: "How much does a kitchen remodel cost in Seattle?",
    answer: "A kitchen remodel in Seattle typically costs between $25,000 and $85,000 depending on scope. A minor refresh (cosmetic updates, new countertops, cabinet refacing) averages $25,000–$40,000, while a major renovation with custom cabinetry, premium countertops, and layout changes runs $50,000–$85,000+. Best Kitchen and Bathroom Remodeling provides fixed-price quotes with no change-order surprises."
  },
  {
    question: "How long does a bathroom remodel take?",
    answer: "A standard bathroom remodel in Seattle takes 3–6 weeks from demolition to completion. A half-bath refresh can be done in 2–3 weeks, while a full primary bathroom renovation with custom tile, walk-in shower, and heated floors may take 6–8 weeks. We provide a detailed project timeline before work begins and keep you updated throughout the process."
  },
  {
    question: "Do I need a permit for kitchen remodeling in Seattle?",
    answer: "Yes, most kitchen remodels in Seattle require permits, especially if you're moving plumbing, adding electrical circuits, removing walls, or changing the layout. Cosmetic-only updates (paint, hardware, countertop replacement on existing cabinets) typically don't need permits. Best Kitchen and Bathroom Remodeling handles all permit applications and inspections with the City of Seattle Department of Construction and Inspections (SDCI)."
  },
  {
    question: "What's the best countertop material for Seattle kitchens?",
    answer: "The most popular countertop materials for Seattle kitchens are quartz, granite, and butcher block. Quartz is the top choice for its durability, low maintenance, and wide color range. Granite offers natural beauty and heat resistance. Butcher block adds warmth to Pacific Northwest-style kitchens. We also install marble, soapstone, and recycled glass countertops depending on your style and budget."
  },
  {
    question: "How do I choose a remodeling contractor in Seattle?",
    answer: "When choosing a remodeling contractor in Seattle, verify their Washington State contractor license, check reviews on Google and the BBB, ask for references from recent local projects, confirm they carry liability insurance and a surety bond, and get a detailed written estimate. Best Kitchen and Bathroom Remodeling is licensed, bonded, insured, with a 4.9-star rating from 230+ Google reviews and 15+ years of experience."
  },
  {
    question: "What's the ROI of a kitchen remodel in Seattle?",
    answer: "A kitchen remodel in Seattle typically returns 60–80% of the investment at resale, making it one of the highest-ROI home improvements. Minor kitchen remodels recoup about 75–80%, while major upscale renovations return around 55–65%. In Seattle's competitive housing market, an updated kitchen can also help your home sell faster. A modern kitchen is consistently ranked as the #1 feature buyers look for."
  },
];
---

<BaseLayout
  title="Kitchen & Bathroom Remodeling Seattle | Best KB Remodeling"
  description="Seattle's top-rated kitchen and bathroom remodeling company. Award-winning craftsmanship, transparent pricing. Serving Seattle, Bellevue, Kirkland & beyond. Call for a free estimate!"
>
  <SchemaOrganization />
  <SchemaProduct />
  <SchemaHowTo
    name="How to Get Started with Best Kitchen and Bathroom Remodeling"
    description="Our simple 5-step process makes kitchen and bathroom remodeling stress-free. From free consultation to 5-year warranty, here's how we deliver award-winning remodels in Seattle."
    steps={howToSteps}
    totalTime="P6W"
    estimatedCost={{ currency: 'USD', minValue: 15000, maxValue: 85000 }}
  />
  <HeroHome />
  <TrustBar />
  <ServicesOverview />
  <BeforeAfterShowcase />
  <WhyChooseUs />
  <GuaranteeSection />
  <FeaturedProjects />
  <CostGuideTeaser />
  <AreasServed />
  <Testimonials />
  <ProcessSteps />
  <RecentWorkBanner />
  <BlogPreview />

  <!-- FAQ Section for AI Search Visibility -->
  <SchemaFAQ items={faqItems} />
  <section class="py-16 lg:py-24 bg-gray-50" data-speakable>
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">
          Frequently Asked Questions About Remodeling in Seattle
        </h2>
        <p class="text-lg text-gray-600 font-[family-name:var(--font-body)]">
          These are the questions we hear every week in consultations — about costs, timelines, and what to actually expect during construction.
        </p>
      </div>
      <div class="space-y-4">
        {faqItems.map((item, i) => (
          <details class="group bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden" {...(i === 0 ? { open: true } : {})}>
            <summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-left font-semibold text-primary text-lg font-[family-name:var(--font-heading)] hover:bg-gray-50 transition-colors [&::-webkit-details-marker]:hidden list-none">
              <span>{item.question}</span>
              <svg class="w-5 h-5 text-gray-400 shrink-0 ml-4 transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 leading-relaxed font-[family-name:var(--font-body)]">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA />
</BaseLayout>
