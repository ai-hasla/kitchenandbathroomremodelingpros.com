---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { SITE } from '@/lib/constants';

const breadcrumbs = [{ label: 'Reviews', href: '/reviews/' }];

const reviews = [
  {
    name: 'Jennifer & Mark Thompson',
    date: '2026-01-15',
    rating: 5,
    text: 'We hired KB Remodeling Pros for a full kitchen remodel in our 1940s Craftsman in Ballard. From the initial consultation to the final walkthrough, David and his team were exceptional. They helped us design a kitchen that honors the character of our home while adding modern functionality. The custom shaker cabinets, quartz countertops, and herringbone backsplash turned out absolutely stunning. The project was completed on time and within budget. We cannot recommend them highly enough.',
    city: 'Seattle (Ballard)',
    projectType: 'Kitchen Remodel',
  },
  {
    name: 'Robert Nakamura',
    date: '2025-11-22',
    rating: 5,
    text: 'Sarah and the team completely transformed our master bathroom. We went from a cramped, dated space to a spa-like retreat with a walk-in shower, heated floors, and a beautiful floating vanity. The tile work is immaculate — every cut, every grout line is perfect. They also handled all the plumbing upgrades and permit work. The crew was respectful of our home, cleaned up every day, and kept us informed throughout the process. Outstanding work from start to finish.',
    city: 'Bellevue',
    projectType: 'Bathroom Remodel',
  },
  {
    name: 'Lisa & Tom Garcia',
    date: '2025-10-08',
    rating: 5,
    text: 'We had both our kitchen and guest bathroom remodeled by KB Remodeling Pros. The kitchen got new cabinets, granite countertops, and a stunning subway tile backsplash. The bathroom received a new tub, vanity, and floor-to-ceiling tile. Both spaces look incredible and the craftsmanship is top-notch. What really sets this company apart is their communication — we always knew what was happening and never felt in the dark. Worth every penny.',
    city: 'Kirkland',
    projectType: 'Kitchen & Bathroom',
  },
  {
    name: 'Amanda Patel',
    date: '2025-09-14',
    rating: 5,
    text: 'I was nervous about doing a major remodel as a first-time homeowner, but KB Remodeling Pros made the entire experience stress-free. Emily helped me select materials that fit my style and budget, and the final result exceeded my wildest expectations. My new kitchen has beautiful two-tone cabinets, a waterfall quartz island, and pendant lighting that makes the whole space feel like it belongs in a magazine. Friends and family cannot believe the transformation.',
    city: 'Redmond',
    projectType: 'Kitchen Remodel',
  },
  {
    name: 'David & Susan Lee',
    date: '2025-08-30',
    rating: 5,
    text: 'We hired them specifically for a shower remodel in our Mercer Island home. Our old shower was leaking and outdated. They replaced everything with a gorgeous frameless glass walk-in shower with large format porcelain tiles and a rain showerhead. The work is flawless and it feels like a luxury hotel. They also discovered and repaired water damage behind the old shower that we didn\'t know about. Honest, skilled, and professional — this is how remodeling should be.',
    city: 'Mercer Island',
    projectType: 'Shower Remodel',
  },
  {
    name: 'Michael Torres',
    date: '2025-07-19',
    rating: 4,
    text: 'Very pleased with our bathroom remodel. The vanity installation and tile work are excellent. The design team helped us make smart choices on materials. Only reason for 4 stars instead of 5 is that the project ran about a week longer than initially estimated due to a back-ordered faucet. However, they kept us informed about the delay and the finished product is beautiful. Would still recommend to anyone looking for quality bathroom work in the Seattle area.',
    city: 'Renton',
    projectType: 'Bathroom Remodel',
  },
  {
    name: 'Karen & Jim Wright',
    date: '2025-06-05',
    rating: 5,
    text: 'We are so happy we chose KB Remodeling Pros for our kitchen cabinet refacing project. We loved our kitchen layout but the cabinets were showing their age. Rather than spending $50K+ on new cabinets, they refaced our existing ones with beautiful maple doors and soft-close hardware, plus added new crown molding. The result is a kitchen that looks completely brand new for a fraction of the cost. James is a true craftsman — his attention to detail is remarkable.',
    city: 'Sammamish',
    projectType: 'Cabinet Refacing',
  },
  {
    name: 'Rachel Kim',
    date: '2025-04-22',
    rating: 5,
    text: 'I had my condo bathroom completely gutted and rebuilt by this team. They installed a beautiful tile shower with a bench, new vanity with undermount sink, and gorgeous hex tile flooring. Working in a condo has its own challenges with HOA rules and noise restrictions, but they handled everything professionally. The project manager Sarah coordinated with our building management seamlessly. The bathroom is now the most beautiful room in my home.',
    city: 'Seattle (Capitol Hill)',
    projectType: 'Bathroom Remodel',
  },
  {
    name: 'Brian & Nancy O\'Brien',
    date: '2025-03-11',
    rating: 5,
    text: 'KB Remodeling Pros did an amazing job on our aging-in-place bathroom renovation. My mother-in-law is moving in with us and we needed a fully accessible bathroom. They installed a zero-threshold shower with grab bars, a comfort-height toilet, a roll-under vanity, and non-slip tile flooring. Everything is ADA compliant but still looks beautiful — it doesn\'t feel institutional at all. They clearly understood our needs and delivered a space that prioritizes both safety and aesthetics.',
    city: 'Bothell',
    projectType: 'Aging-in-Place Bathroom',
  },
  {
    name: 'Alex & Priya Mehta',
    date: '2025-01-28',
    rating: 5,
    text: 'We had countertops installed throughout our kitchen — a beautiful Calacatta quartz on the perimeter and butcher block on the island. The templating was precise and the installation was seamless. The seams are virtually invisible and the edges are perfectly finished. The crew was in and out in a single day and left everything spotless. We have already recommended them to two of our neighbors. Great work at a fair price.',
    city: 'Woodinville',
    projectType: 'Countertop Installation',
  },
];

const averageRating = SITE.reviews.rating;
const totalReviews = SITE.reviews.count;

const aggregateSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE.name,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: averageRating,
    reviewCount: totalReviews,
    bestRating: 5,
    worstRating: 1,
  },
  review: reviews.map((r) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.name },
    datePublished: r.date,
    reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5 },
    reviewBody: r.text,
  })),
};
---

<BaseLayout
  title="Reviews | Seattle Kitchen & Bathroom Remodeling"
  description="Read verified reviews from Seattle homeowners who chose Kitchen & Bathroom Remodeling Pros. 4.9-star rating across 53 reviews. See why our clients love us."
  canonical={`${SITE.url}/reviews/`}
>
  <SchemaBreadcrumb items={breadcrumbs} />
  <script type="application/ld+json" set:html={JSON.stringify(aggregateSchema)} />

  <!-- Hero -->
  <section class="bg-primary pt-32 pb-16">
    <Container>
      <div class="max-w-3xl" data-reveal>
        <p class="text-accent font-semibold uppercase tracking-wider text-sm mb-3">Testimonials</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[family-name:var(--font-heading)] text-white mb-6">What Our Clients Say</h1>
        <p class="text-lg text-white/80 leading-relaxed">
          Don't just take our word for it. Read what Seattle homeowners have to say about their experience working with us.
        </p>
      </div>
    </Container>
  </section>

  <!-- Aggregate Rating -->
  <section class="py-12 bg-accent-light border-b border-border">
    <Container>
      <div class="flex flex-col md:flex-row items-center justify-between gap-6" data-reveal>
        <div class="flex items-center gap-6">
          <div class="text-center">
            <p class="text-5xl font-bold font-[family-name:var(--font-heading)] text-primary">{averageRating}</p>
            <div class="flex gap-0.5 mt-1">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
          </div>
          <div>
            <p class="text-lg font-semibold text-primary">Based on {totalReviews} verified reviews</p>
            <p class="text-body-text text-sm">Collected from Google, Yelp, and Houzz</p>
          </div>
        </div>
        <a
          href={SITE.social.google}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-white border border-border px-5 py-3 rounded-lg hover:shadow-md transition-shadow font-medium text-primary"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Review Us on Google
        </a>
      </div>
    </Container>
  </section>

  <!-- Reviews Grid -->
  <section class="py-20">
    <Container>
      <div class="grid md:grid-cols-2 gap-8" data-reveal-stagger>
        {reviews.map((review) => (
          <div class="bg-white border border-border rounded-2xl p-8 hover:shadow-lg transition-shadow">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-semibold text-primary">{review.name}</h3>
                <p class="text-sm text-muted">{review.city} &middot; {review.projectType}</p>
              </div>
              <time class="text-sm text-muted" datetime={review.date}>
                {new Date(review.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
              </time>
            </div>
            <div class="flex gap-0.5 mb-4">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class={`w-4 h-4 ${i < review.rating ? 'text-accent' : 'text-border'}`} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <p class="text-body-text leading-relaxed text-sm">{review.text}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary">
    <Container>
      <div class="text-center max-w-2xl mx-auto" data-reveal>
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-white mb-4">Ready to Start Your Project?</h2>
        <p class="text-white/80 text-lg mb-8">
          Join our growing list of happy homeowners. Get a free, no-obligation estimate for your kitchen or bathroom remodel today.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/get-a-quote/" variant="primary" size="lg">Get a Free Estimate</Button>
          <Button href={`tel:${SITE.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-primary">Call {SITE.phone}</Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
