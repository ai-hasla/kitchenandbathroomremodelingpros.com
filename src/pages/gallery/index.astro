---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { SITE } from '@/lib/constants';

const breadcrumbs = [{ label: 'Gallery', href: '/gallery/' }];

const galleryImages = [
  { src: '/images/gallery-blue-kitchen.jpg', alt: 'Navy blue and white kitchen with brass hardware — Seattle kitchen remodel', title: 'Navy Blue Kitchen', location: 'Capitol Hill, Seattle', category: 'Kitchen' },
  { src: '/images/gallery-master-bath.jpg', alt: 'Master bathroom with freestanding tub and marble shower — Bellevue bathroom remodel', title: 'Luxury Spa Bathroom', location: 'Bellevue', category: 'Bathroom' },
  { src: '/images/gallery-modern-kitchen.jpg', alt: 'Modern kitchen with brick wall and concrete floors — urban condo remodel', title: 'Urban Modern Kitchen', location: 'South Lake Union, Seattle', category: 'Kitchen' },
  { src: '/images/gallery-classic-bath.jpg', alt: 'Classic bathroom with beadboard wainscoting and hex tile floor', title: 'Classic Craftsman Bath', location: 'Ballard, Seattle', category: 'Bathroom' },
  { src: '/images/gallery-walnut-kitchen.jpg', alt: 'Walnut and dark countertop contemporary kitchen with floor-to-ceiling windows', title: "Chef's Kitchen", location: 'Mercer Island', category: 'Kitchen' },
  { src: '/images/gallery-luxury-shower.jpg', alt: 'Calacatta marble walk-in shower with LED niche lighting', title: 'Marble Walk-In Shower', location: 'Kirkland', category: 'Bathroom' },
  { src: '/images/gallery-white-kitchen.jpg', alt: 'All-white kitchen with herringbone marble floor and crystal chandeliers', title: 'Elegant White Kitchen', location: 'Sammamish', category: 'Kitchen' },
  { src: '/images/gallery-green-kitchen.jpg', alt: 'Green cabinetry with butcher block island and terracotta tile floor', title: 'Farmhouse Kitchen', location: 'Woodinville', category: 'Kitchen' },
  { src: '/images/gallery-grey-bath.jpg', alt: 'Grey bathroom with subway tile walk-in shower and framed mirror', title: 'Grey & White Bath', location: 'Renton', category: 'Bathroom' },
  { src: '/images/gallery-cozy-kitchen.jpg', alt: 'Warm kitchen with rattan pendant lights and rustic wood island', title: 'Cozy Farmhouse Kitchen', location: 'Bothell', category: 'Kitchen' },
  { src: '/images/gallery-bath-detail.jpg', alt: 'Bathroom vanity detail with spa towels, candle, and marble wall', title: 'Spa Bath Details', location: 'Redmond', category: 'Bathroom' },
  { src: '/images/service-aging-in-place.jpg', alt: 'Accessible bathroom with floating vanity and glass shower enclosure', title: 'Accessible Bath Remodel', location: 'Edmonds', category: 'Bathroom' },
];

const beforeAfterProjects = [
  { before: '/images/before-kitchen-1.jpg', after: '/images/after-kitchen-1.jpg', title: 'Complete Kitchen Transformation', location: 'Queen Anne, Seattle', desc: 'Dated oak cabinets and granite transformed into a stunning white and navy blue kitchen with marble countertops.' },
  { before: '/images/before-kitchen-2.jpg', after: '/images/after-kitchen-2.jpg', title: 'Open Concept Kitchen', location: 'Wallingford, Seattle', desc: 'Dark, dated kitchen opened up with new island, marble backsplash, and teal cabinetry.' },
  { before: '/images/before-kitchen-3.jpg', after: '/images/after-kitchen-3.jpg', title: 'Modern Family Kitchen', location: 'Kirkland', desc: 'Cluttered kitchen with mixed materials remodeled into a clean, modern space with patterned tile backsplash.' },
  { before: '/images/before-kitchen-4.jpg', after: '/images/after-kitchen-4.jpg', title: 'Blue Island Kitchen Remodel', location: 'Sammamish', desc: 'Cramped family kitchen expanded with large blue island, herringbone backsplash, and pendant lights.' },
  { before: '/images/before-bathroom-1.jpg', after: '/images/after-bathroom-1.jpg', title: 'Master Bathroom Renovation', location: 'Bellevue', desc: 'Outdated master bath with freestanding tub transformed into a luxurious marble spa with glass shower.' },
  { before: '/images/before-bathroom-2.jpg', after: '/images/after-bathroom-2.jpg', title: 'Small Bathroom Makeover', location: 'Capitol Hill, Seattle', desc: 'Dated pink tile bathroom completely modernized with sleek grey tones and modern lighting.' },
  { before: '/images/before-bathroom-3.jpg', after: '/images/after-bathroom-3.jpg', title: 'Attic Bathroom Conversion', location: 'Ballard, Seattle', desc: 'Basic powder room transformed into a stunning shower with skylight, marble bench, and brass hardware.' },
  { before: '/images/before-bathroom-4.jpg', after: '/images/after-bathroom-4.jpg', title: 'Double Vanity Renovation', location: 'Redmond', desc: 'Outdated corner vanity replaced with modern walnut floating double vanity and porcelain tile.' },
];

const gallerySchema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Kitchen & Bathroom Remodeling Gallery — Seattle Projects',
  description: 'Portfolio of kitchen and bathroom remodeling projects completed across the greater Seattle area by Best KB Remodeling.',
  url: `${SITE.url}/gallery/`,
  publisher: {
    '@type': 'HomeAndConstructionBusiness',
    name: SITE.name,
  },
};
---

<BaseLayout
  title="Kitchen & Bathroom Remodeling Gallery | Seattle Projects"
  description="Browse our portfolio of kitchen and bathroom remodeling projects in Seattle, Bellevue, Kirkland, and beyond. See our craftsmanship across kitchens, bathrooms, cabinetry, countertops, and more."
  canonical={`${SITE.url}/gallery/`}
  ogImage="/images/og/og-gallery.png"
>
  <SchemaBreadcrumb items={breadcrumbs} />
  <script type="application/ld+json" set:html={JSON.stringify(gallerySchema)} />

  <!-- Hero -->
  <section class="bg-primary pt-32 pb-16">
    <Container>
      <div class="max-w-3xl" data-reveal>
        <p class="text-accent font-semibold uppercase tracking-wider text-sm mb-3">Our Work</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[family-name:var(--font-heading)] text-white mb-6">Project Gallery</h1>
        <p class="text-lg text-white/80 leading-relaxed">
          Explore our portfolio of completed kitchen and bathroom remodeling projects across the greater Seattle area. From Ballard Craftsman kitchens to Bellevue spa bathrooms, each project showcases our commitment to quality craftsmanship.
        </p>
      </div>
    </Container>
  </section>

  <!-- Project Gallery Grid -->
  <section class="py-20">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-14" data-reveal>
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">Our Completed Projects</h2>
        <p class="text-muted text-lg">Browse kitchen and bathroom remodels across Seattle, Bellevue, Kirkland, and beyond.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-reveal-stagger>
        {galleryImages.map((img) => (
          <div class="rounded-2xl overflow-hidden border border-border hover:shadow-xl transition-all duration-300 group">
            <div class="aspect-[4/3] overflow-hidden">
              <picture>
                <source srcset={img.src.replace('.jpg', '.webp')} type="image/webp" />
                <img src={img.src} alt={img.alt} width="1200" height="800" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </picture>
            </div>
            <div class="p-5">
              <span class="text-xs font-semibold text-accent uppercase tracking-wider">{img.category}</span>
              <h3 class="text-lg font-[family-name:var(--font-heading)] text-primary mt-1">{img.title}</h3>
              <p class="text-sm text-muted">{img.location}</p>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Before & After Section -->
  <section class="py-20 bg-light">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-14" data-reveal>
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">Before & After Transformations</h2>
        <p class="text-muted text-lg">See the dramatic difference our craftsmanship makes. Real projects, real results.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8" data-reveal-stagger>
        {beforeAfterProjects.map((project) => (
          <div class="rounded-2xl overflow-hidden border border-border bg-white">
            <div class="grid grid-cols-2">
              <div class="relative">
                <picture>
                  <source srcset={project.before.replace('.jpg', '.webp')} type="image/webp" />
                  <img src={project.before} alt={`Before: ${project.title}`} width="600" height="400" loading="lazy" decoding="async" class="w-full h-48 sm:h-56 object-cover" />
                </picture>
                <span class="absolute top-3 left-3 bg-dark-text/80 text-white text-xs font-semibold px-2.5 py-1 rounded-full">Before</span>
              </div>
              <div class="relative">
                <picture>
                  <source srcset={project.after.replace('.jpg', '.webp')} type="image/webp" />
                  <img src={project.after} alt={`After: ${project.title}`} width="600" height="400" loading="lazy" decoding="async" class="w-full h-48 sm:h-56 object-cover" />
                </picture>
                <span class="absolute top-3 left-3 bg-accent text-white text-xs font-semibold px-2.5 py-1 rounded-full">After</span>
              </div>
            </div>
            <div class="p-5">
              <h3 class="text-lg font-[family-name:var(--font-heading)] text-primary">{project.title}</h3>
              <p class="text-sm text-muted mb-2">{project.location}</p>
              <p class="text-sm text-body-text leading-relaxed">{project.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary">
    <Container>
      <div class="text-center max-w-2xl mx-auto" data-reveal>
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-white mb-4">Love What You See?</h2>
        <p class="text-white/80 text-lg mb-8">
          Let's create something beautiful together. Schedule your free in-home consultation and get a no-obligation estimate for your kitchen or bathroom remodel.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="https://nexfield.pro/crm/book?u=137" target="_blank" rel="noopener noreferrer" variant="primary" size="lg">Get a Free Estimate</Button>
          <Button href="/contact/" variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-primary">Contact Us</Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
