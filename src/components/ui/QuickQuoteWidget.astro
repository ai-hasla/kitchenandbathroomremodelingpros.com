---
---

<div class="bg-primary rounded-2xl p-6">
  <h3 class="text-lg font-[family-name:var(--font-heading)] text-white mb-1">
    Quick Quote
  </h3>
  <p class="text-white/70 text-xs mb-5 leading-relaxed">
    Tell us what you need &mdash; we'll get back to you within 24 hours.
  </p>

  <form id="quick-quote-form" class="flex flex-col gap-4" data-quick-quote>
    <!-- Project Type -->
    <fieldset>
      <legend class="text-white text-sm font-medium mb-2">Project Type</legend>
      <div class="flex gap-2">
        <label class="flex-1 cursor-pointer">
          <input type="radio" name="project_type" value="Kitchen" class="sr-only peer" required />
          <span class="block text-center text-xs font-semibold py-2 px-2 rounded-lg border border-white/20 text-white/70 peer-checked:bg-accent peer-checked:border-accent peer-checked:text-white transition-colors">
            Kitchen
          </span>
        </label>
        <label class="flex-1 cursor-pointer">
          <input type="radio" name="project_type" value="Bathroom" class="sr-only peer" />
          <span class="block text-center text-xs font-semibold py-2 px-2 rounded-lg border border-white/20 text-white/70 peer-checked:bg-accent peer-checked:border-accent peer-checked:text-white transition-colors">
            Bathroom
          </span>
        </label>
        <label class="flex-1 cursor-pointer">
          <input type="radio" name="project_type" value="Both" class="sr-only peer" />
          <span class="block text-center text-xs font-semibold py-2 px-2 rounded-lg border border-white/20 text-white/70 peer-checked:bg-accent peer-checked:border-accent peer-checked:text-white transition-colors">
            Both
          </span>
        </label>
      </div>
    </fieldset>

    <!-- ZIP Code -->
    <div>
      <label for="qq-zip" class="text-white text-sm font-medium mb-1.5 block">ZIP Code</label>
      <input
        type="text"
        id="qq-zip"
        name="zip_code"
        placeholder="98101"
        pattern="[0-9]{5}"
        maxlength="5"
        required
        class="w-full px-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent"
      />
    </div>

    <!-- Phone Number -->
    <div>
      <label for="qq-phone" class="text-white text-sm font-medium mb-1.5 block">Phone Number</label>
      <input
        type="tel"
        id="qq-phone"
        name="phone"
        placeholder="(206) 555-1234"
        required
        class="w-full px-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent"
      />
    </div>

    <!-- Honeypot -->
    <div class="absolute -left-[9999px]" aria-hidden="true">
      <label for="qq-website">Website</label>
      <input type="text" id="qq-website" name="website" tabindex="-1" autocomplete="off" />
    </div>

    <!-- Submit -->
    <button
      type="submit"
      class="w-full bg-accent hover:bg-accent-hover text-white font-semibold py-2.5 px-4 rounded-lg transition-colors text-sm shadow-lg shadow-accent/20 cursor-pointer"
    >
      Get Your Quote in 24 Hours
    </button>
  </form>

  <!-- Success Message (hidden by default) -->
  <div id="quick-quote-success" class="hidden text-center py-6">
    <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center mx-auto mb-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
      </svg>
    </div>
    <p class="text-white font-semibold mb-1">Thank You!</p>
    <p class="text-white/70 text-xs">We'll call you within 24 hours to discuss your project.</p>
  </div>
</div>

<script>
  document.querySelectorAll('[data-quick-quote]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;

      // Check honeypot
      const honeypot = formEl.querySelector<HTMLInputElement>('[name="website"]');
      if (honeypot && honeypot.value) return;

      // Hide form, show success
      formEl.classList.add('hidden');
      const success = formEl.parentElement?.querySelector('#quick-quote-success');
      if (success) {
        success.classList.remove('hidden');
      }
    });
  });
</script>
