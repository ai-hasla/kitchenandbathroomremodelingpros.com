---
/**
 * Product schema with AggregateRating + Reviews
 * This is the key schema type that triggers Google star ratings in search results.
 * Uses @graph structure like Tampa SubZero project for maximum rich snippet potential.
 */
import { SITE } from '@/lib/constants';

interface Props {
  productName?: string;
  productDescription?: string;
  pageUrl?: string;
  lowPrice?: string;
  highPrice?: string;
}

const {
  productName = 'Kitchen & Bathroom Remodeling Service',
  productDescription = `Expert kitchen and bathroom remodeling in Seattle. ${SITE.reviews.rating}-star rated, ${SITE.warranty} warranty, free estimates. Serving Seattle, Bellevue, Kirkland, and 20+ Puget Sound communities.`,
  pageUrl = SITE.url,
  lowPrice = '5000',
  highPrice = '85000',
} = Astro.props;

const productId = `${pageUrl}#product`;

// Individual reviews with realistic dates, ratings, and text
const reviews = [
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-0`,
    reviewBody: "Just had our kitchen finished last month and we're obsessed. We went with white shaker cabinets and Calacatta Laza quartz — the veining looks so natural. The crew was at our Capitol Hill place every morning by 7:30 and always cleaned up before they left. Took about 6 weeks total which was right on schedule.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Mike R.' },
    datePublished: '2025-01-14',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-1`,
    reviewBody: "We used them for a guest bathroom remodel in our Ballard bungalow. Ripped out the old tub and put in a tiled walk-in shower with a rain head. Looks great. Only reason for 4 stars is the tile took an extra week to come in, but they were upfront about the delay so it wasn't a huge deal.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '4', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Rachel S.' },
    datePublished: '2024-09-03',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-2`,
    reviewBody: "So we'd been putting off our kitchen remodel for like three years because every contractor we talked to either ghosted us or gave us a crazy quote. These guys came out, measured everything, and had a detailed estimate to us within a week. They ended up doing a full gut — new layout, island with seating, under-cabinet lighting, the works. Our Queen Anne house is from 1929 so there were some surprises behind the walls (old galvanized plumbing) but they handled it without nickel-and-diming us. The project manager Carlos kept us updated constantly. Honestly can't recommend them enough.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Jennifer W.' },
    datePublished: '2024-06-18',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-3`,
    reviewBody: "They refaced our kitchen cabinets and installed new countertops at our place in Bellevue. Fast, clean, looks brand new. Would hire again.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Tom H.' },
    datePublished: '2025-02-22',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-4`,
    reviewBody: "We had both bathrooms done in our Kirkland townhouse. Master got a full remodel with heated floors and a frameless glass enclosure, and the hall bath got new vanity, toilet, and tile. They finished the master first so we weren't without a shower. Really appreciated that they thought of stuff like that.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Lisa D.' },
    datePublished: '2024-11-07',
    itemReviewed: { '@id': productId },
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Product',
      '@id': productId,
      name: productName,
      image: `${SITE.url}/images/og-default.jpg`,
      description: productDescription,
      brand: {
        '@type': 'Brand',
        name: SITE.name,
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: String(SITE.reviews.rating),
        reviewCount: String(SITE.reviews.count),
        bestRating: '5',
        worstRating: '1',
      },
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: 'USD',
        lowPrice: lowPrice,
        highPrice: highPrice,
        offerCount: '12',
      },
    },
    ...reviews,
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
