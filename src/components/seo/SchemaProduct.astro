---
/**
 * Product schema with AggregateRating + Reviews
 * This is the key schema type that triggers Google star ratings in search results.
 * Uses @graph structure for maximum rich snippet potential.
 */
import { SITE } from '@/lib/constants';

interface Props {
  productName?: string;
  productDescription?: string;
  pageUrl?: string;
  lowPrice?: string;
  highPrice?: string;
}

const {
  productName = 'Kitchen & Bathroom Remodeling Service',
  productDescription = `Expert kitchen and bathroom remodeling in Seattle. ${SITE.reviews.rating}-star rated with ${SITE.reviews.count}+ verified reviews. ${SITE.warranty} warranty, free estimates. Serving Seattle, Bellevue, Kirkland, and 20+ Puget Sound communities since ${SITE.yearFounded}.`,
  pageUrl = SITE.url,
  lowPrice = '5000',
  highPrice = '85000',
} = Astro.props;

const productId = `${pageUrl}#product`;

const reviews = [
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-0`,
    reviewBody: "Just had our kitchen finished last month and we're obsessed. We went with white shaker cabinets and Calacatta Laza quartz — the veining looks so natural. The crew was at our Capitol Hill place every morning by 7:30 and always cleaned up before they left. Took about 6 weeks total which was right on schedule.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Mike R.' },
    datePublished: '2025-01-14',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-1`,
    reviewBody: "We used them for a guest bathroom remodel in our Ballard bungalow. Ripped out the old tub and put in a tiled walk-in shower with a rain head. Looks great. Only reason for 4 stars is the tile took an extra week to come in, but they were upfront about the delay so it wasn't a huge deal.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '4', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Rachel S.' },
    datePublished: '2024-09-03',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-2`,
    reviewBody: "So we'd been putting off our kitchen remodel for like three years because every contractor we talked to either ghosted us or gave us a crazy quote. These guys came out, measured everything, and had a detailed estimate to us within a week. They ended up doing a full gut — new layout, island with seating, under-cabinet lighting, the works. Our Queen Anne house is from 1929 so there were some surprises behind the walls (old galvanized plumbing) but they handled it without nickel-and-diming us. The project manager Carlos kept us updated constantly. Honestly can't recommend them enough.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Jennifer W.' },
    datePublished: '2024-06-18',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-3`,
    reviewBody: "They refaced our kitchen cabinets and installed new countertops at our place in Bellevue. Fast, clean, looks brand new. Would hire again.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Tom H.' },
    datePublished: '2025-02-22',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-4`,
    reviewBody: "We had both bathrooms done in our Kirkland townhouse. Master got a full remodel with heated floors and a frameless glass enclosure, and the hall bath got new vanity, toilet, and tile. They finished the master first so we weren't without a shower. Really appreciated that they thought of stuff like that.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Lisa D.' },
    datePublished: '2024-11-07',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-5`,
    reviewBody: "Hired them for a complete master bath renovation in our Magnolia colonial. Curbless shower with penny round floor tile, freestanding soaking tub, and custom double vanity with quartzite top. The heated floor alone was worth every penny — especially in Seattle winters. Project took 5 weeks and they hit every timeline milestone.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Patricia & James L.' },
    datePublished: '2025-03-02',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-6`,
    reviewBody: "Kitchen remodel in our 1960s Renton split-level. Knocked out the wall between kitchen and dining room, added a 9-foot island, pot filler over the range, and under-cabinet LEDs. The electrician rewired the whole kitchen — went from 2 circuits to 6. Couldn't be happier with how it turned out.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Derek M.' },
    datePublished: '2024-12-15',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-7`,
    reviewBody: "We're retired and wanted our Shoreline ranch bathroom updated for aging in place. They installed grab bars that actually look stylish, a zero-threshold shower, comfort-height toilet, and lever-handle faucets. Everything is ADA-compliant but doesn't look clinical. Thoughtful design throughout.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Barbara & Frank H.' },
    datePublished: '2025-01-28',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-8`,
    reviewBody: "Third project with this crew — first was our Redmond master bath in 2022, then the kitchen in 2023, and just finished the guest bath. Consistency is what keeps us coming back. Same attention to detail every time. This round we did a floating vanity with vessel sink and wood-look porcelain floor tile. Looks incredible.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Anita K.' },
    datePublished: '2025-02-18',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-9`,
    reviewBody: "Had our Everett rancher kitchen redone. New soft-close cabinets, butcher block island, quartz perimeter counters, and subway tile backsplash. Simple clean look. Budget was tight at $32K and they worked within it without cutting corners. Only minor issue was a backordered faucet that added 4 days.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '4', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Steve & Carol P.' },
    datePublished: '2024-10-22',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-10`,
    reviewBody: "Converted our Puyallup tub/shower combo into a gorgeous walk-in with frameless glass and a rain showerhead. Added a built-in bench and two recessed niches. The waterproofing they did (Kerdi system) gives us total peace of mind. Crew was polite and kept the work area clean daily.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Melissa T.' },
    datePublished: '2024-08-19',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-11`,
    reviewBody: "We spent months getting quotes for our Mercer Island kitchen and these guys were the most detailed and transparent. Full gut remodel — custom walnut cabinets, Dekton countertops, Wolf appliances, and a butler's pantry. $82K project finished in 10 weeks. The 3D rendering matched the final product almost perfectly. Would recommend to anyone doing high-end work.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'David & Susan C.' },
    datePublished: '2025-03-08',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-12`,
    reviewBody: "They installed new LVP flooring throughout our Kent home — kitchen, bathrooms, hallways, about 1,200 sq ft total. Transitions between rooms are seamless and the waterproof rating was important for us with kids and dogs. Done in 3 days. Very efficient crew.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Amanda J.' },
    datePublished: '2024-07-11',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-13`,
    reviewBody: "Our Federal Way condo needed a bathroom refresh — new vanity, mirror, light fixtures, and they retiled the shower. Nothing too crazy but the result is night and day. Professional from the estimate through final walkthrough. The project manager sent us photos at end of each day which we appreciated.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Linda W.' },
    datePublished: '2024-11-30',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-14`,
    reviewBody: "Went with a mid-range kitchen remodel for our Lynnwood rambler — white shaker cabinets, grey quartz counters, stainless hardware, and new LVP flooring. $38K all in. Nothing fancy but the quality of the cabinet install and countertop fabrication is excellent. Neighbors have already asked for their number.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Ryan & Jessica B.' },
    datePublished: '2025-02-08',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-15`,
    reviewBody: "Had them renovate two bathrooms in our Tacoma Victorian. Hall bath got a clawfoot tub restoration and hex tile floor to stay period-appropriate. Master got a modern walk-in shower with body sprays. They really understood the difference in style we wanted between the two rooms. Excellent craftsmanship on both.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Catherine & Paul D.' },
    datePublished: '2024-05-14',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-16`,
    reviewBody: "Cabinet refacing plus new granite countertops in our Issaquah kitchen. Went from dated honey oak to modern grey shaker — completely transformed. Whole project was 5 days and we only had to eat out for two of them. Great value compared to a full remodel.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Nancy G.' },
    datePublished: '2024-09-25',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-17`,
    reviewBody: "Our Sammamish master bath remodel exceeded expectations. Linear drain shower, large-format tile, backlit mirror, and heated towel rack. The tile setter was a true artisan — every cut around the niche was perfect. Small delay getting the glass enclosure but they communicated proactively.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '4', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Andrew L.' },
    datePublished: '2025-01-05',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-18`,
    reviewBody: "We had a terrible experience with another contractor who left our Bothell kitchen half-finished. These guys came in, assessed the damage, and completed the job at a fair price. New countertops, fixed the cabinet alignment issues, installed the backsplash properly. They basically rescued our project. Can't thank them enough.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Maria & Carlos V.' },
    datePublished: '2024-08-07',
    itemReviewed: { '@id': productId },
  },
  {
    '@type': 'Review' as const,
    '@id': `${productId}-review-19`,
    reviewBody: "Installed Calacatta Borghini quartz throughout our Woodinville kitchen — island, perimeter, and wet bar. Beautiful material and the fabrication was flawless. Template to install was about 12 days. The installers were careful with our new cabinets and floor. Highly recommend for countertop work.",
    reviewRating: { '@type': 'Rating' as const, ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person' as const, name: 'Helen S.' },
    datePublished: '2024-12-20',
    itemReviewed: { '@id': productId },
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Product',
      '@id': productId,
      name: productName,
      image: `${SITE.url}/images/og-default.jpg`,
      description: productDescription,
      brand: {
        '@type': 'Brand',
        name: SITE.name,
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: String(SITE.reviews.rating),
        reviewCount: String(SITE.reviews.count),
        bestRating: '5',
        worstRating: '1',
      },
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: 'USD',
        lowPrice: lowPrice,
        highPrice: highPrice,
        offerCount: '12',
      },
    },
    ...reviews,
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
