// Fallback reviews for services not in the map
const defaultReviews = [
  {
    body: "They did a great job on our home improvement project in the Seattle area. Professional crew, on schedule, and the finished product looks exactly like what they showed us in the design phase. The project manager was responsive and kept us informed throughout.",
    rating: '5', author: 'Mark P.', date: '2025-01-20',
  },
  {
    body: "Hired them for work at our Bellevue home and were impressed by the attention to detail. Fair pricing and transparent communication throughout the project. Would definitely recommend.",
    rating: '5', author: 'Susan E.', date: '2024-09-12',
  },
  {
    body: "Solid work at our Kirkland place. A small detail needed adjustment after completion and they came back the next day to take care of it. Would recommend for quality home remodeling work.",
    rating: '4', author: 'Dan V.', date: '2024-07-03',
  },
  {
    body: "Professional and reliable. Our Redmond home project was completed within the quoted timeline and budget. The crew was courteous and cleaned up each day before leaving. Very satisfied with the final result.",
    rating: '5', author: 'Jennifer & Chris W.', date: '2025-02-05',
  },
  {
    body: "Great experience working with this team on our Sammamish home. They handled the permitting, kept us informed with daily updates, and the craftsmanship is excellent. Already planning our next project with them.",
    rating: '5', author: 'Andrea M.', date: '2024-11-18',
  },
];

const reviews = reviewsByService[slug] || defaultReviews;

// Price ranges by service
const priceRanges: Record<string, { low: string; high: string }> = {
  'kitchen-remodeling': { low: '25000', high: '85000' },
  'bathroom-remodeling': { low: '15000', high: '50000' },
  'cabinet-refacing': { low: '5000', high: '15000' },
  'countertop-installation': { low: '3000', high: '12000' },
  'tile-installation': { low: '2000', high: '10000' },
  'shower-remodeling': { low: '5000', high: '20000' },
  'bathtub-replacement': { low: '3000', high: '12000' },
  'vanity-installation': { low: '1500', high: '6000' },
  'kitchen-layout-design': { low: '2000', high: '8000' },
  'custom-cabinetry': { low: '10000', high: '35000' },
  'flooring-installation': { low: '3000', high: '15000' },
  'aging-in-place': { low: '5000', high: '30000' },
};

const range = priceRanges[slug] || { low: '5000', high: '30000' };

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': serviceId,
      serviceType: serviceName,
      provider: {
        '@type': 'HomeAndConstructionBusiness',
        '@id': `${SITE.url}/#organization`,
        name: SITE.name,
        telephone: SITE.phone,
        url: SITE.url,
      },
      areaServed: {
        '@type': 'State',
        name: 'Washington',
      },
      description: serviceDescription,
      url: serviceUrl,
    },
    {
      '@type': 'Product',
      '@id': productId,
      name: `${serviceName} in Seattle, WA`,
      description: serviceDescription,
      image: `${SITE.url}/images/og-default.jpg`,
      brand: {
        '@type': 'Brand',
        name: SITE.name,
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: String(SITE.reviews.rating),
        reviewCount: String(SITE.reviews.count),
        bestRating: '5',
        worstRating: '1',
      },
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: 'USD',
        lowPrice: range.low,
        highPrice: range.high,
        offerCount: String(features.length || 6),
      },
    },
    ...reviews.map((r, i) => ({
      '@type': 'Review' as const,
      '@id': `${productId}-review-${i}`,
      reviewBody: r.body,
      reviewRating: {
        '@type': 'Rating' as const,
        ratingValue: r.rating,
        bestRating: '5',
      },
      author: {
        '@type': 'Person' as const,
        name: r.author,
      },
      datePublished: r.date,
      itemReviewed: { '@id': productId },
    })),
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
