---
/**
 * Service schema with Product wrapper for Google star ratings.
 * Uses Product + AggregateRating + individual Reviews (like Tampa model).
 */
import { SITE } from '@/lib/constants';

interface Props {
  serviceName: string;
  serviceDescription: string;
  serviceUrl: string;
  slug: string;
  features?: string[];
}

const {
  serviceName,
  serviceDescription,
  serviceUrl,
  slug,
  features = [],
} = Astro.props;

const productId = `${serviceUrl}#product`;
const serviceId = `${serviceUrl}#service`;

// Realistic, unique reviews per service slug
const reviewsByService: Record<string, Array<{
  body: string;
  rating: string;
  author: string;
  date: string;
}>> = {
  'kitchen-remodeling': [
    {
      body: "We gutted our 1940s kitchen in Wallingford — new layout, soft-close cabinets, quartz island with waterfall edge. Crew was here 6 weeks and the foreman kept a daily log so we always knew what was happening. End result is night and day from what we had before.",
      rating: '5', author: 'Brian K.', date: '2025-01-18',
    },
    {
      body: "Had them redo our galley kitchen in a Bellevue split-level. Went from cramped and dark to open with tons of counter space. The electrician they brought in for under-cabinet lighting did great work too. Came in about $2k under the original estimate.",
      rating: '5', author: 'Natalie P.', date: '2024-08-22',
    },
    {
      body: "Good overall experience for our Redmond townhouse kitchen. Cabinets and counters look fantastic. Backsplash grout had a small color mismatch they came back and fixed within a couple days. Four stars only because the permit process added time, but that's not really their fault.",
      rating: '4', author: 'Greg M.', date: '2024-11-05',
    },
  ],
  'bathroom-remodeling': [
    {
      body: "Master bath remodel in our Sammamish home. Curbless shower with linear drain, floating vanity, large-format porcelain tile. They waterproofed everything with Schluter membrane which made us feel confident about the wet area. Done in just under 4 weeks.",
      rating: '5', author: 'Angela T.', date: '2025-02-10',
    },
    {
      body: "We had a small hall bathroom updated in our Fremont cottage — new tub surround, vanity, toilet, and LVP floor. Quick 2-week turnaround. Looks clean and modern without going overboard on budget.",
      rating: '5', author: 'Dave R.', date: '2024-10-14',
    },
    {
      body: "Solid work on our Kirkland ensuite. Frameless glass shower enclosure turned out beautiful. Only knock is the tile delivery was delayed a few days, but they communicated the schedule change right away.",
      rating: '4', author: 'Priya N.', date: '2024-07-29',
    },
  ],
  'cabinet-refacing': [
    {
      body: "Refaced our oak cabinets with a white shaker style and added soft-close hinges. Kitchen in our Bothell rambler looks completely different and we saved a ton vs full replacement. Took 4 days.",
      rating: '5', author: 'Jim L.', date: '2025-01-03',
    },
    {
      body: "They refaced the uppers and replaced the lowers in our Renton condo kitchen. The color match between old and new is seamless — visitors can't tell which ones are original. Great value.",
      rating: '5', author: 'Carla F.', date: '2024-09-17',
    },
    {
      body: "Happy with the cabinet refacing on our Lynnwood home. Nice improvement for the price. One drawer front had a slight warp and they replaced it next day, no argument.",
      rating: '4', author: 'Scott W.', date: '2024-06-08',
    },
  ],
  'countertop-installation': [
    {
      body: "Calacatta Laza quartz on our kitchen island and perimeter counters. Template, fabrication, and install took about 10 days total. Seams are nearly invisible. The crew was careful not to damage our new cabinets during install.",
      rating: '5', author: 'Megan C.', date: '2025-02-01',
    },
    {
      body: "Replaced old laminate with granite in our Issaquah kitchen. They did the sink cutout on-site and everything lined up perfectly. Reasonable price compared to three other quotes we got.",
      rating: '5', author: 'Tony B.', date: '2024-11-20',
    },
    {
      body: "Good countertop install at our Edmonds place. Marble in the master bath and quartz in the kitchen. The marble edge profile we picked looks elegant. Whole process took about two weeks from template to install.",
      rating: '4', author: 'Sarah J.', date: '2024-08-11',
    },
  ],
  'tile-installation': [
    {
      body: "Large-format 24x48 porcelain on our master bath floor and shower walls in Mercer Island. Zero lippage, even grout lines. They used Ditra membrane underneath so I'm not worried about cracking. Really impressive tile work.",
      rating: '5', author: 'Kevin O.', date: '2025-01-25',
    },
    {
      body: "Subway tile backsplash with a herringbone accent strip in our Queen Anne kitchen. Clean install, tight joints, and they finished in two days. Exactly what we wanted.",
      rating: '5', author: 'Laura H.', date: '2024-12-03',
    },
    {
      body: "They tiled our entryway and two bathrooms at our Shoreline split-level. Consistent work across all three areas. One grout color ended up slightly different between batches but they fixed the affected section.",
      rating: '4', author: 'Pete D.', date: '2024-07-15',
    },
  ],
  'shower-remodeling': [
    {
      body: "Converted our old fiberglass tub/shower combo to a tiled walk-in with frameless glass in Maple Leaf. Added a bench and recessed niche. Completely changed the feel of the bathroom — it's like a spa now.",
      rating: '5', author: 'Christine A.', date: '2025-02-14',
    },
    {
      body: "They built a curbless shower in our Burien ranch for my mom's accessibility needs. Beveled floor tile, grab bars, handheld showerhead on a slide bar. Well thought out and she loves it.",
      rating: '5', author: 'Mark T.', date: '2024-10-01',
    },
    {
      body: "Good shower remodel in our Federal Way place. Rain head and body sprays work great. Glass enclosure is solid. Scheduling took a little longer than expected to get started but once they were on-site it moved fast.",
      rating: '4', author: 'Diana L.', date: '2024-05-22',
    },
  ],
  'bathtub-replacement': [
    {
      body: "Swapped out our cracked acrylic tub for a soaking tub in our Green Lake bungalow. They had to rework some of the plumbing underneath but it was all included in the quote. No surprises.",
      rating: '5', author: 'Jason F.', date: '2025-01-09',
    },
    {
      body: "Replaced the old cast iron tub in our Ravenna home. Getting that thing out was a project in itself but the crew handled it. New alcove tub with tile surround looks sharp.",
      rating: '5', author: 'Amy G.', date: '2024-09-28',
    },
    {
      body: "Decent tub replacement job at our Kenmore condo. New tub fits great and the tile work around it is clean. Took a day longer than quoted because of a plumbing fitting issue but they sorted it out.",
      rating: '4', author: 'Ron S.', date: '2024-06-30',
    },
  ],
  'vanity-installation': [
    {
      body: "Installed a 60-inch double vanity in our Woodinville master bath. Custom mirror, new faucets, and they tied in the plumbing for both sinks. Turned out exactly like the design render they showed us.",
      rating: '5', author: 'Beth M.', date: '2025-02-05',
    },
    {
      body: "New floating vanity in our guest bath at our Capitol Hill condo. Sleek look, good storage, LED mirror above it. Quick install — they were in and out in one day.",
      rating: '5', author: 'Nate K.', date: '2024-10-19',
    },
    {
      body: "They put in matching vanities in our two upstairs bathrooms in Lake Forest Park. Both look great. One of the drawer pulls was loose on arrival and they tightened it during the final walkthrough.",
      rating: '4', author: 'Julie R.', date: '2024-08-04',
    },
  ],
};

// Fallback reviews for services not in the map
const defaultReviews = [
  {
    body: "They did a great job on our home improvement project in the Seattle area. Professional crew, on schedule, and the finished product looks exactly like what they showed us in the design phase.",
    rating: '5', author: 'Mark P.', date: '2025-01-20',
  },
  {
    body: "Hired them for work at our Bellevue home and were impressed by the attention to detail. Fair pricing and transparent communication throughout the project.",
    rating: '5', author: 'Susan E.', date: '2024-09-12',
  },
  {
    body: "Solid work at our Kirkland place. A small detail needed adjustment after completion and they came back the next day to take care of it. Would recommend.",
    rating: '4', author: 'Dan V.', date: '2024-07-03',
  },
];

const reviews = reviewsByService[slug] || defaultReviews;

// Price ranges by service
const priceRanges: Record<string, { low: string; high: string }> = {
  'kitchen-remodeling': { low: '25000', high: '85000' },
  'bathroom-remodeling': { low: '15000', high: '50000' },
  'cabinet-refacing': { low: '5000', high: '15000' },
  'countertop-installation': { low: '3000', high: '12000' },
  'tile-installation': { low: '2000', high: '10000' },
  'shower-remodeling': { low: '5000', high: '20000' },
  'bathtub-replacement': { low: '3000', high: '12000' },
  'vanity-installation': { low: '1500', high: '6000' },
  'kitchen-layout-design': { low: '2000', high: '8000' },
  'custom-cabinetry': { low: '10000', high: '35000' },
  'flooring-installation': { low: '3000', high: '15000' },
  'aging-in-place': { low: '5000', high: '30000' },
};

const range = priceRanges[slug] || { low: '5000', high: '30000' };

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': serviceId,
      serviceType: serviceName,
      provider: {
        '@type': 'HomeAndConstructionBusiness',
        '@id': `${SITE.url}/#organization`,
        name: SITE.name,
        telephone: SITE.phone,
        url: SITE.url,
      },
      areaServed: {
        '@type': 'State',
        name: 'Washington',
      },
      description: serviceDescription,
      url: serviceUrl,
    },
    {
      '@type': 'Product',
      '@id': productId,
      name: `${serviceName} in Seattle, WA`,
      description: serviceDescription,
      brand: {
        '@type': 'Brand',
        name: SITE.name,
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: String(SITE.reviews.rating),
        reviewCount: String(SITE.reviews.count),
        bestRating: '5',
        worstRating: '1',
      },
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: 'USD',
        lowPrice: range.low,
        highPrice: range.high,
        offerCount: String(features.length || 6),
      },
    },
    ...reviews.map((r, i) => ({
      '@type': 'Review' as const,
      '@id': `${productId}-review-${i}`,
      reviewBody: r.body,
      reviewRating: {
        '@type': 'Rating' as const,
        ratingValue: r.rating,
        bestRating: '5',
      },
      author: {
        '@type': 'Person' as const,
        name: r.author,
      },
      datePublished: r.date,
      itemReviewed: { '@id': productId },
    })),
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
