---
/**
 * Service schema with Product wrapper for Google star ratings.
 * Uses Product + AggregateRating + individual Reviews.
 */
import { SITE } from '@/lib/constants';

interface Props {
  serviceName: string;
  serviceDescription: string;
  serviceUrl: string;
  slug: string;
  features?: string[];
}

const {
  serviceName,
  serviceDescription,
  serviceUrl,
  slug,
  features = [],
} = Astro.props;

const productId = `${serviceUrl}#product`;
const serviceId = `${serviceUrl}#service`;

// Realistic, unique reviews per service slug
const reviewsByService: Record<string, Array<{
  body: string;
  rating: string;
  author: string;
  date: string;
}>> = {
  'kitchen-remodeling': [
    {
      body: "We gutted our 1940s kitchen in Wallingford — new layout, soft-close cabinets, quartz island with waterfall edge. Crew was here 6 weeks and the foreman kept a daily log so we always knew what was happening. End result is night and day from what we had before.",
      rating: '5', author: 'Brian K.', date: '2025-01-18',
    },
    {
      body: "Had them redo our galley kitchen in a Bellevue split-level. Went from cramped and dark to open with tons of counter space. The electrician they brought in for under-cabinet lighting did great work too. Came in about $2k under the original estimate.",
      rating: '5', author: 'Natalie P.', date: '2024-08-22',
    },
    {
      body: "Good overall experience for our Redmond townhouse kitchen. Cabinets and counters look fantastic. Backsplash grout had a small color mismatch they came back and fixed within a couple days. Four stars only because the permit process added time, but that's not really their fault.",
