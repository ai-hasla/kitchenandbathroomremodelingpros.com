---
import Container from '@/components/ui/Container.astro';
---

<section class="py-8 lg:py-10 border-y border-border/50">
  <Container>
    <div class="flex flex-col items-center gap-5" data-reveal>
      <p class="text-xs uppercase tracking-[0.2em] text-muted font-[family-name:var(--font-body)] font-medium">
        Trusted By Homeowners &amp; Featured On
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4 lg:gap-6">

        <!-- Google Reviews -->
        <div class="flex items-center gap-2 bg-white border border-border rounded-xl px-5 py-3 shadow-sm">
          <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <div class="flex flex-col leading-tight">
            <div class="flex items-center gap-1">
              <span class="text-sm font-bold text-gray-900">4.9</span>
              <div class="flex">
                <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              </div>
            </div>
            <span class="text-[11px] text-gray-500">250+ Google Reviews</span>
          </div>
        </div>

        <!-- BBB A+ Rated -->
        <div class="flex items-center gap-2.5 bg-white border border-border rounded-xl px-5 py-3 shadow-sm">
          <div class="w-8 h-8 bg-[#005A8B] rounded-md flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-1 6h2v2h-2V7zm0 4h2v6h-2v-6z"/></svg>
          </div>
          <div class="flex flex-col leading-tight">
            <span class="text-sm font-bold text-[#005A8B]">BBB</span>
            <div class="flex items-center gap-1">
              <span class="bg-[#005A8B] text-white text-[10px] font-bold px-1.5 py-0.5 rounded">A+</span>
              <span class="text-[11px] text-gray-500">Rated</span>
            </div>
          </div>
        </div>

        <!-- Houzz Best of -->
        <div class="flex items-center gap-2.5 bg-white border border-border rounded-xl px-5 py-3 shadow-sm">
          <div class="w-8 h-8 bg-[#4DBC15] rounded-md flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12.5 3.5v5.8H6.3V24h5.5V12.5h5.9V24h5.5V3.5z"/></svg>
          </div>
          <div class="flex flex-col leading-tight">
            <span class="text-sm font-bold text-gray-900">Best of Houzz</span>
            <span class="text-[11px] text-gray-500">Service Award</span>
          </div>
        </div>

        <!-- Angi Top Rated -->
        <div class="flex items-center gap-2.5 bg-white border border-border rounded-xl px-5 py-3 shadow-sm">
          <div class="w-8 h-8 bg-[#FF6153] rounded-md flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <div class="flex flex-col leading-tight">
            <span class="text-sm font-bold text-gray-900">Angi</span>
            <span class="text-[11px] text-gray-500">Top Rated Pro</span>
          </div>
        </div>

        <!-- HomeAdvisor -->
        <div class="flex items-center gap-2.5 bg-white border border-border rounded-xl px-5 py-3 shadow-sm">
          <div class="w-8 h-8 bg-[#F68B24] rounded-md flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
          </div>
          <div class="flex flex-col leading-tight">
            <span class="text-sm font-bold text-gray-900">HomeAdvisor</span>
            <span class="text-[11px] text-gray-500">Screened & Approved</span>
          </div>
        </div>

      </div>
    </div>
  </Container>
</section>
