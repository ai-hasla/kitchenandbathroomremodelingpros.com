---
import Container from '@/components/ui/Container.astro';
---

<section class="py-8 lg:py-10 border-y border-border/50">
  <Container>
    <div class="flex flex-col items-center gap-5" data-reveal>
      <p class="text-xs uppercase tracking-[0.2em] text-muted font-[family-name:var(--font-body)] font-medium">
        Trusted By Homeowners &amp; Featured On
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3 lg:gap-4">
        <div class="bg-white border border-border rounded-lg px-4 py-2 text-sm font-semibold text-muted select-none">
          Houzz
        </div>
        <div class="bg-white border border-border rounded-lg px-4 py-2 text-sm font-semibold text-muted select-none">
          Angi
        </div>
        <div class="bg-white border border-border rounded-lg px-4 py-2 text-sm font-semibold text-muted select-none">
          BBB A+
        </div>
        <div class="bg-white border border-border rounded-lg px-4 py-2 text-sm font-semibold text-muted select-none">
          HomeAdvisor
        </div>
        <div class="bg-white border border-border rounded-lg px-4 py-2 text-sm font-semibold text-muted select-none">
          Google 4.9&#9733;
        </div>
      </div>
    </div>
  </Container>
</section>
