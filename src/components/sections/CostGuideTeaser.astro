---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';

const tiers = [
  {
    label: 'Refresh & Update',
    range: '$18,000 - $34,000',
    color: 'bg-accent/30',
    width: 'w-1/3',
    description: 'New countertops, cabinet refacing, updated fixtures and hardware — keep your layout, upgrade the look',
  },
  {
    label: 'Mid-Range Remodel',
    range: '$38,000 - $72,000',
    color: 'bg-accent/60',
    width: 'w-2/3',
    description: 'New cabinets (e.g., semi-custom shaker), quartz counters, new appliances, and minor layout changes',
  },
  {
    label: 'Full-Scale Renovation',
    range: '$85,000 - $160,000+',
    color: 'bg-accent',
    width: 'w-full',
    description: 'Gut to studs, move walls and plumbing, custom cabinetry, premium appliances like Wolf or Thermador',
  },
];
---

<section class="py-16 lg:py-24">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-center">
      <!-- Left Content (3 cols) -->
      <div class="lg:col-span-3" data-reveal="left">
        <p class="text-accent uppercase tracking-widest text-sm font-semibold mb-4 font-[family-name:var(--font-body)]">
          WHAT IT ACTUALLY COSTS
        </p>

        <h2 class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-primary leading-tight mb-6">
          Real Kitchen Remodel Costs in Seattle (2025&ndash;2026)
        </h2>

        <p class="text-body-text leading-relaxed mb-4 max-w-xl">
          A mid-range kitchen remodel in Seattle runs $38,000&ndash;$72,000 &mdash; roughly
          15&ndash;20% above the national average. Why? Higher labor rates, Seattle SDCI permit
          fees (currently $1,200+ for major remodels), and the fact that most pre-1980 homes
          need electrical or plumbing brought up to current code once you open the walls.
        </p>
        <p class="text-body-text leading-relaxed mb-8 max-w-xl">
          <strong>Pro tip:</strong> If your home was built before 1978, budget an extra
          $2,000&ndash;$5,000 for lead paint testing and possible abatement &mdash; it's
          required by EPA law once you disturb painted surfaces, and most contractors
          won't tell you that upfront. We always flag it at the consultation so there are
          no budget surprises later.
        </p>

        <!-- Cost Tiers -->
        <div class="space-y-6 mb-10">
          {tiers.map((tier) => (
            <div>
              <div class="flex items-baseline justify-between mb-2">
                <h3 class="font-semibold text-dark-text">{tier.label}</h3>
                <span class="text-accent font-semibold font-[family-name:var(--font-heading)]">{tier.range}</span>
              </div>
              <div class="h-2 bg-light rounded-full overflow-hidden">
                <div class={`h-full rounded-full ${tier.color} ${tier.width}`}></div>
              </div>
              <p class="text-sm text-muted mt-1.5">{tier.description}</p>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <Button variant="primary" href="/cost-guides/kitchen-remodel-cost-seattle/">
            Read Full Kitchen Cost Guide
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
          <Button variant="outline" href="/cost-guides/bathroom-remodel-cost-seattle/">
            Bathroom Cost Guide
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
        </div>
      </div>

      <!-- Right Visual (2 cols) -->
      <div class="lg:col-span-2 hidden lg:block" data-reveal="right">
        <div class="relative">
          <!-- Decorative stacked cards -->
          <div class="absolute -top-4 -left-4 w-full h-full bg-accent/10 rounded-2xl"></div>
          <div class="absolute -top-2 -left-2 w-full h-full bg-accent/5 rounded-2xl"></div>

          <div class="relative bg-white rounded-2xl shadow-xl border border-border p-8">
            <div class="text-center mb-6">
              <p class="text-sm text-muted uppercase tracking-wide font-semibold mb-1">Seattle Median</p>
              <p class="text-4xl font-[family-name:var(--font-heading)] text-primary font-bold">$52,000</p>
              <p class="text-sm text-muted">Kitchen Remodel Cost</p>
            </div>

            <div class="border-t border-border pt-6 space-y-4">
              {tiers.map((tier) => (
                <div class="flex items-center gap-3">
                  <div class={`w-3 h-3 rounded-full flex-shrink-0 ${tier.color}`}></div>
                  <div class="flex-1">
                    <p class="text-sm font-medium text-dark-text">{tier.label}</p>
                  </div>
                  <p class="text-sm font-semibold text-accent">{tier.range}</p>
                </div>
              ))}
            </div>

            <div class="mt-6 pt-6 border-t border-border">
              <div class="flex items-center gap-2 text-sm text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>Prices based on 2025-2026 Seattle market data</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
