---
import { SERVICES } from '@/lib/constants';
import Container from '@/components/ui/Container.astro';

const displayedServices = SERVICES.slice(0, 6);

const serviceIcons: Record<string, string> = {
  kitchen: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M3 6v12a2 2 0 002 2h14a2 2 0 002-2V6M3 6l1-3h16l1 3M8 6v4M16 6v4M12 6v4M7 14h4M13 14h4" />
  </svg>`,
  bathroom: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3 13h18v2a4 4 0 01-4 4H7a4 4 0 01-4-4v-2zM5 13V6a2 2 0 012-2h1a2 2 0 012 2v1M21 17l-1 4M3 17l1 4" />
  </svg>`,
  cabinets: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h18v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5zM3 12h18M12 5v16M9 8.5h-2M17 8.5h-2M9 15.5h-2M17 15.5h-2" />
  </svg>`,
  countertop: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 10h16M4 10v8a2 2 0 002 2h12a2 2 0 002-2v-8M4 10l2-6h12l2 6M8 14v2M16 14v2" />
  </svg>`,
  tile: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
  </svg>`,
  shower: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v3m0 0a3 3 0 013 3H9a3 3 0 013-3zM7 12v1m2-1v2m2-2v3m2-3v2m2-2v1M5 20h14" />
  </svg>`,
};

function getIcon(iconName: string): string {
  return serviceIcons[iconName] || serviceIcons['kitchen'];
}
---

<section class="py-16 lg:py-24">
  <Container>
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12 lg:mb-16" data-reveal>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-[family-name:var(--font-heading)] text-dark-text mb-4">
        Our Remodeling Services
      </h2>
      <p class="text-lg text-muted font-[family-name:var(--font-body)]">
        From concept to completion, we deliver exceptional results
      </p>
    </div>

    <!-- Service Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-12" data-reveal-stagger>
      {displayedServices.map((service) => (
        <a
          href={`/services/${service.slug}/`}
          class="group bg-white rounded-2xl p-6 lg:p-8 border border-border shadow-sm hover:-translate-y-1 hover:shadow-lg transition-all duration-300"
        >
          <!-- Icon -->
          <div class="w-12 h-12 rounded-full bg-accent-light text-accent flex items-center justify-center mb-5">
            <Fragment set:html={getIcon(service.icon)} />
          </div>

          <!-- Title -->
          <h3 class="text-lg font-semibold text-dark-text mb-2 font-[family-name:var(--font-heading)]">
            {service.title}
          </h3>

          <!-- Description -->
          <p class="text-sm text-muted mb-4 font-[family-name:var(--font-body)] leading-relaxed">
            {service.shortDescription}
          </p>

          <!-- Learn More Link -->
          <span class="text-accent font-medium text-sm hover:underline inline-flex items-center gap-1 font-[family-name:var(--font-body)] group-hover:underline">
            Learn More
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>

    <!-- View All CTA -->
    <div class="text-center" data-reveal>
      <a
        href="/services/"
        class="inline-flex items-center gap-2 text-accent font-semibold hover:underline text-base font-[family-name:var(--font-body)] transition-colors"
      >
        View All Services
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </Container>
</section>
