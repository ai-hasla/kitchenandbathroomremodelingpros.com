---
import { SERVICES } from '@/lib/constants';
import Container from '@/components/ui/Container.astro';

const displayedServices = SERVICES.slice(0, 6);
---

<section class="py-16 lg:py-24">
  <Container>
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12 lg:mb-16" data-reveal>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-[family-name:var(--font-heading)] text-dark-text mb-4">
        Our Remodeling Services
      </h2>
      <p class="text-lg text-muted font-[family-name:var(--font-body)]">
        From concept to completion, we deliver exceptional results
      </p>
    </div>

    <!-- Service Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-12" data-reveal-stagger>
      {displayedServices.map((service) => (
        <a
          href={`/services/${service.slug}/`}
          class="group relative rounded-2xl overflow-hidden shadow-sm hover:-translate-y-1 hover:shadow-xl transition-all duration-300 aspect-[4/3]"
        >
          <!-- Background Image -->
          <picture>
            <source srcset={`/images/service-${service.slug}.webp`} type="image/webp" />
            <img
              src={`/images/service-${service.slug}.jpg`}
              alt={`${service.title} in Seattle`}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              width="800"
              height="600"
              loading="lazy"
            />
          </picture>

          <!-- Gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>

          <!-- Content -->
          <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-6">
            <!-- Category badge -->
            <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wider mb-2 ${
              service.category === 'kitchen'
                ? 'bg-accent/90 text-white'
                : service.category === 'bathroom'
                  ? 'bg-primary/90 text-white'
                  : 'bg-white/20 text-white backdrop-blur-sm'
            }`}>
              {service.category}
            </span>

            <!-- Title -->
            <h3 class="text-xl font-semibold text-white mb-1.5 font-[family-name:var(--font-heading)]">
              {service.title}
            </h3>

            <!-- Description -->
            <p class="text-sm text-white/80 mb-3 font-[family-name:var(--font-body)] leading-relaxed line-clamp-2">
              {service.shortDescription}
            </p>

            <!-- Learn More -->
            <span class="text-accent font-medium text-sm inline-flex items-center gap-1.5 font-[family-name:var(--font-body)] group-hover:gap-2.5 transition-all duration-300">
              Learn More<span class="sr-only"> about {service.title}</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- View All CTA -->
    <div class="text-center" data-reveal>
      <a
        href="/services/"
        class="inline-flex items-center gap-2 text-accent font-semibold hover:underline text-base font-[family-name:var(--font-body)] transition-colors"
      >
        View All 12 Services
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </Container>
</section>
