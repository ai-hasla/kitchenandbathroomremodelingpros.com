---
import Container from '@/components/ui/Container.astro';

const comparisons = [
  {
    before: 'https://images.unsplash.com/photo-1484154218962-a197022b5858?auto=format&fit=crop&w=1200&q=80',
    after: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?auto=format&fit=crop&w=1200&q=80',
    caption: 'Complete Kitchen Transformation',
    location: 'Capitol Hill, Seattle',
  },
  {
    before: 'https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?auto=format&fit=crop&w=1200&q=80',
    after: 'https://images.unsplash.com/photo-1631679706909-1844bbd07221?auto=format&fit=crop&w=1200&q=80',
    caption: 'Luxury Bathroom Renovation',
    location: 'Queen Anne, Seattle',
  },
];
---

<section class="bg-primary py-16 lg:py-24">
  <Container>
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12 lg:mb-16" data-reveal>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-[family-name:var(--font-heading)] text-white mb-4">
        See the Transformation
      </h2>
      <p class="text-lg text-white/70 font-[family-name:var(--font-body)]">
        Drag the slider to reveal stunning before &amp; after results
      </p>
    </div>

    <!-- Comparison Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8" data-reveal>
      {comparisons.map((item) => (
        <div>
          <div
            class="comparison-slider aspect-[4/3] rounded-xl overflow-hidden relative cursor-col-resize select-none"
            style="--pos: 50%"
          >
            <!-- After Image (full background) -->
            <img
              src={item.after}
              alt={`After: ${item.caption}`}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />

            <!-- Before Image (clipped) -->
            <div class="comparison-before">
              <img
                src={item.before}
                alt={`Before: ${item.caption}`}
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
              />
            </div>

            <!-- Labels -->
            <div class="absolute top-4 left-4 z-20 bg-black/60 backdrop-blur-sm text-white text-xs font-semibold uppercase tracking-wider px-3 py-1.5 rounded-full pointer-events-none font-[family-name:var(--font-body)]">
              Before
            </div>
            <div class="absolute top-4 right-4 z-20 bg-accent/90 backdrop-blur-sm text-white text-xs font-semibold uppercase tracking-wider px-3 py-1.5 rounded-full pointer-events-none font-[family-name:var(--font-body)]">
              After
            </div>

            <!-- Slider Handle (circle on the divider line) -->
            <div
              class="absolute top-1/2 -translate-y-1/2 z-20 pointer-events-none flex items-center justify-center"
              style="left: var(--pos, 50%); transform: translate(-50%, -50%)"
            >
              <div class="w-10 h-10 rounded-full bg-white shadow-lg flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l-3 3 3 3m8-6l3 3-3 3" />
                </svg>
              </div>
            </div>

            <!-- Range Input (invisible, controls the slider) -->
            <input
              type="range"
              min="0"
              max="100"
              value="50"
              class="comparison-range absolute inset-0 w-full h-full opacity-0 cursor-col-resize z-30"
              aria-label={`Before and after slider for ${item.caption}`}
            />
          </div>

          <!-- Caption -->
          <div class="mt-4 text-center">
            <p class="text-white font-semibold font-[family-name:var(--font-heading)] text-lg">
              {item.caption}
            </p>
            <p class="text-white/60 text-sm font-[family-name:var(--font-body)] mt-1">
              {item.location}
            </p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>

<script>
  document.querySelectorAll('.comparison-slider').forEach((slider) => {
    const range = slider.querySelector('.comparison-range') as HTMLInputElement;
    if (!range) return;

    range.addEventListener('input', () => {
      (slider as HTMLElement).style.setProperty('--pos', range.value + '%');
    });
  });
</script>
