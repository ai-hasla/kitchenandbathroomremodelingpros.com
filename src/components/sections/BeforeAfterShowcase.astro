---
import Container from '@/components/ui/Container.astro';

const comparisons = [
  {
    before: '/images/before-kitchen-1.jpg',
    after: '/images/after-kitchen-1.jpg',
    caption: 'Complete Kitchen Transformation',
    location: 'Capitol Hill, Seattle',
  },
  {
    before: '/images/before-bathroom-1.jpg',
    after: '/images/after-bathroom-1.jpg',
    caption: 'Luxury Bathroom Renovation',
    location: 'Queen Anne, Seattle',
  },
];
---

<section class="bg-primary py-16 lg:py-24">
  <Container>
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12 lg:mb-16" data-reveal>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-[family-name:var(--font-heading)] text-white mb-4">
        See the Transformation
      </h2>
      <p class="text-lg text-white/70 font-[family-name:var(--font-body)]">
        Drag the slider to reveal stunning before &amp; after results
      </p>
    </div>

    <!-- Comparison Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8" data-reveal>
      {comparisons.map((item) => (
        <div>
          <div
            class="relative aspect-[4/3] rounded-xl overflow-hidden select-none cursor-col-resize"
            data-compare
          >
            <!-- After Image (full background) -->
            <img
              src={item.after}
              alt={`After: ${item.caption}`}
              class="absolute inset-0 w-full h-full object-cover pointer-events-none"
              loading="lazy"
              draggable="false"
            />

            <!-- Before Image (clipped overlay) -->
            <div
              class="absolute inset-0 overflow-hidden"
              style="width: 50%"
              data-compare-overlay
            >
              <img
                src={item.before}
                alt={`Before: ${item.caption}`}
                class="absolute inset-0 w-full h-full object-cover pointer-events-none"
                style="min-width: var(--compare-width, 100%)"
                loading="lazy"
                draggable="false"
              />
            </div>

            <!-- Labels -->
            <div class="absolute top-4 left-4 z-20 bg-black/60 backdrop-blur-sm text-white text-xs font-semibold uppercase tracking-wider px-3 py-1.5 rounded-full pointer-events-none font-[family-name:var(--font-body)]">
              Before
            </div>
            <div class="absolute top-4 right-4 z-20 bg-accent/90 backdrop-blur-sm text-white text-xs font-semibold uppercase tracking-wider px-3 py-1.5 rounded-full pointer-events-none font-[family-name:var(--font-body)]">
              After
            </div>

            <!-- Drag to compare hint -->
            <div
              class="absolute inset-0 z-30 flex items-center justify-center pointer-events-none transition-opacity duration-700"
              data-compare-hint
            >
              <span class="bg-black/60 backdrop-blur-sm text-white text-sm font-medium px-4 py-2 rounded-full font-[family-name:var(--font-body)]">
                Drag to compare
              </span>
            </div>

            <!-- Divider line -->
            <div
              class="absolute top-0 bottom-0 z-20 pointer-events-none"
              style="left: 50%"
              data-compare-handle
            >
              <!-- Vertical line -->
              <div class="absolute top-0 bottom-0 left-1/2 -translate-x-1/2 w-0.5 bg-white shadow-[0_0_6px_rgba(0,0,0,0.4)]"></div>
              <!-- Circle handle -->
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white shadow-lg flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l-3 3 3 3m8-6l3 3-3 3" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Caption -->
          <div class="mt-4 text-center">
            <p class="text-white font-semibold font-[family-name:var(--font-heading)] text-lg">
              {item.caption}
            </p>
            <p class="text-white/60 text-sm font-[family-name:var(--font-body)] mt-1">
              {item.location}
            </p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-compare]').forEach((container) => {
    const overlay = container.querySelector<HTMLElement>('[data-compare-overlay]');
    const handle = container.querySelector<HTMLElement>('[data-compare-handle]');
    const hint = container.querySelector<HTMLElement>('[data-compare-hint]');
    const beforeImg = overlay?.querySelector<HTMLImageElement>('img');
    if (!overlay || !handle || !beforeImg) return;

    let isDragging = false;

    function setPosition(x: number) {
      const rect = container.getBoundingClientRect();
      let pct = ((x - rect.left) / rect.width) * 100;
      pct = Math.max(0, Math.min(100, pct));
      overlay!.style.width = pct + '%';
      handle!.style.left = pct + '%';
      // Make the before image span the full container width
      beforeImg!.style.minWidth = (rect.width) + 'px';
    }

    function onStart(x: number) {
      isDragging = true;
      container.style.willChange = 'auto';
      if (hint) {
        hint.style.opacity = '0';
        setTimeout(() => hint.remove(), 700);
      }
      setPosition(x);
    }

    function onMove(x: number) {
      if (!isDragging) return;
      requestAnimationFrame(() => setPosition(x));
    }

    function onEnd() {
      isDragging = false;
      container.style.willChange = '';
    }

    // Mouse events
    container.addEventListener('mousedown', (e) => {
      e.preventDefault();
      onStart(e.clientX);
    });
    window.addEventListener('mousemove', (e) => onMove(e.clientX));
    window.addEventListener('mouseup', onEnd);

    // Touch events
    container.addEventListener('touchstart', (e) => {
      onStart(e.touches[0].clientX);
    }, { passive: true });
    window.addEventListener('touchmove', (e) => {
      if (isDragging) onMove(e.touches[0].clientX);
    }, { passive: true });
    window.addEventListener('touchend', onEnd);

    // Set initial before image width on load/resize
    function syncWidth() {
      beforeImg!.style.minWidth = container.getBoundingClientRect().width + 'px';
    }
    syncWidth();
    window.addEventListener('resize', syncWidth);
  });
</script>
