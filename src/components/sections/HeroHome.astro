---
import { SITE } from '@/lib/constants';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
---

<section class="relative overflow-hidden">
  <!-- Background image with Ken Burns zoom -->
  <div class="absolute inset-0 z-0">
    <picture>
      <source srcset="/images/hero-home.webp" type="image/webp" />
      <img
        src="/images/hero-home.jpg"
        alt="Modern white kitchen with marble countertops"
        class="h-full w-full object-cover animate-hero-zoom"
        width="2000"
        height="1333"
        loading="eager"
        fetchpriority="high"
      />
    </picture>
  </div>

  <!-- Dark gradient overlay -->
  <div class="absolute inset-0 z-1 bg-gradient-to-r from-black/80 via-black/60 to-transparent"></div>

  <!-- Content -->
  <div class="relative z-10 pt-28 sm:pt-36 lg:pt-40 pb-12 sm:pb-14 lg:pb-16">
    <Container>
      <div class="max-w-2xl">
        <!-- Eyebrow -->
        <p
          class="text-accent text-xs sm:text-sm font-semibold uppercase tracking-widest mb-3 sm:mb-4 font-[family-name:var(--font-body)]"
          data-reveal
        >
          15 Years Remodeling Seattle Homes &mdash; 500+ Projects Completed
        </p>

        <!-- Heading -->
        <h1
          class="text-[2.5rem] leading-[1.1] sm:text-5xl md:text-6xl lg:text-7xl font-[family-name:var(--font-heading)] text-white sm:leading-tight mb-4 sm:mb-6"
          data-reveal
        >
          Seattle Kitchen &amp;<br />Bathroom Remodeling
        </h1>

        <!-- Speakable summary for AI search engines (hidden on mobile, visible to crawlers) -->
        <p
          class="speakable-summary hidden lg:block text-lg text-white/80 max-w-xl mb-4 font-[family-name:var(--font-body)] leading-relaxed"
          data-reveal
          data-speakable
        >
          Best Kitchen and Bathroom Remodeling is Seattle's top-rated remodeling company with a {SITE.reviews.rating}-star rating from {SITE.reviews.count}+ reviews. We specialize in kitchen remodeling, bathroom renovations, custom cabinetry, and countertop installation across Seattle, Bellevue, Kirkland, and 20+ Puget Sound communities. Fully insured and backed by a 5-year warranty. Free estimates available.
        </p>

        <!-- Subtitle -->
        <p
          class="text-[15px] sm:text-lg text-white/80 max-w-xl mb-5 sm:mb-8 font-[family-name:var(--font-body)] leading-relaxed"
          data-reveal
        >
          <span class="sm:hidden">Award-winning kitchen &amp; bathroom transformations across Seattle &amp; the Eastside.<br />500+ homes remodeled with fixed-price quotes and a 5-year warranty.</span>
          <span class="hidden sm:inline">From dated 1960s galleys to open-concept dream kitchens. From pink-tile bathrooms
          to spa-worthy retreats. We've transformed 500+ Seattle homes &mdash; with fixed-price
          quotes and zero change-order surprises.</span>
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 mb-5 sm:mb-8" data-reveal>
          <Button variant="primary" size="lg" href="https://nexfield.pro/crm/book?u=137" target="_blank" rel="noopener noreferrer">
            Get Your Free Estimate
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
          <Button
            variant="outline"
            size="lg"
            href="/gallery/"
            class="border-white text-white hover:bg-white hover:text-primary"
          >
            View Our Projects
          </Button>
        </div>

        <!-- Trust line -->
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2" data-reveal>
          <div class="flex items-center gap-2">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <span class="text-sm text-white/90 font-medium font-[family-name:var(--font-body)]">
              {SITE.reviews.rating} from {SITE.reviews.count}+ Reviews
            </span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <span class="text-sm text-white/90 font-medium font-[family-name:var(--font-body)]">
              Licensed, Bonded &amp; Insured
            </span>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <!-- Trust Badges Bar — in flow, not absolute -->
  <div class="relative z-10 bg-white/95 backdrop-blur-sm border-t border-border/30">
    <!-- Desktop -->
    <div class="hidden sm:block">
      <Container>
        <div class="py-4 lg:py-5">
          <p class="text-center text-xs uppercase tracking-[0.2em] text-muted font-[family-name:var(--font-body)] font-medium mb-4">
            Trusted by Homeowners &amp; Featured On
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4 lg:gap-5">
            <!-- Google Reviews -->
            <div class="flex items-center gap-2 bg-white border border-border rounded-xl px-5 py-3 shadow-sm">
              <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              <div class="flex flex-col leading-tight">
                <div class="flex items-center gap-1">
                  <span class="text-sm font-bold text-gray-900">{SITE.reviews.rating}</span>
                  <div class="flex">
                    {[1,2,3,4,5].map(() => (
                      <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    ))}
                  </div>
                </div>
                <span class="text-[11px] text-gray-500">{SITE.reviews.count}+ Google Reviews</span>
              </div>
            </div>
            <!-- BBB -->
            <div class="flex items-center gap-2.5 bg-white border border-border rounded-xl px-5 py-3 shadow-sm">
              <div class="w-8 h-8 bg-[#005A8B] rounded-md flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-1 6h2v2h-2V7zm0 4h2v6h-2v-6z"/></svg>
              </div>
              <div class="flex flex-col leading-tight">
                <span class="text-sm font-bold text-[#005A8B]">BBB</span>
                <div class="flex items-center gap-1">
                  <span class="bg-[#005A8B] text-white text-[10px] font-bold px-1.5 py-0.5 rounded">A+</span>
                  <span class="text-[11px] text-gray-500">Rated</span>
                </div>
              </div>
            </div>
            <!-- Houzz -->
            <div class="flex items-center gap-2.5 bg-white border border-border rounded-xl px-5 py-3 shadow-sm">
              <div class="w-8 h-8 bg-[#4DBC15] rounded-md flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12.5 3.5v5.8H6.3V24h5.5V12.5h5.9V24h5.5V3.5z"/></svg>
              </div>
              <div class="flex flex-col leading-tight">
                <span class="text-sm font-bold text-gray-900">Best of Houzz</span>
                <span class="text-[11px] text-gray-500">Service Award</span>
              </div>
            </div>
            <!-- Angi -->
            <div class="flex items-center gap-2.5 bg-white border border-border rounded-xl px-5 py-3 shadow-sm">
              <div class="w-8 h-8 bg-[#FF6153] rounded-md flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div class="flex flex-col leading-tight">
                <span class="text-sm font-bold text-gray-900">Angi</span>
                <span class="text-[11px] text-gray-500">Top Rated Pro</span>
              </div>
            </div>
            <!-- HomeAdvisor -->
            <div class="flex items-center gap-2.5 bg-white border border-border rounded-xl px-5 py-3 shadow-sm">
              <div class="w-8 h-8 bg-[#F68B24] rounded-md flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
              </div>
              <div class="flex flex-col leading-tight">
                <span class="text-sm font-bold text-gray-900">HomeAdvisor</span>
                <span class="text-[11px] text-gray-500">Screened &amp; Approved</span>
              </div>
            </div>
          </div>
        </div>
      </Container>
    </div>

    <!-- Mobile: marquee ticker -->
    <div class="sm:hidden overflow-hidden py-2.5">
      <p class="text-center text-[9px] uppercase tracking-[0.2em] text-muted font-[family-name:var(--font-body)] font-medium mb-2">
        Trusted &amp; Featured On
      </p>
      <div class="trust-marquee">
        <div class="trust-marquee-track">
          <!-- Set 1 -->
          <div class="trust-chip">
            <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span class="font-bold text-xs text-gray-900">{SITE.reviews.rating}</span>
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3 h-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
          </div>
          <div class="trust-chip">
            <div class="w-5 h-5 bg-[#005A8B] rounded flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-1 6h2v2h-2V7zm0 4h2v6h-2v-6z"/></svg>
            </div>
            <span class="font-bold text-xs text-[#005A8B]">BBB A+</span>
          </div>
          <div class="trust-chip">
            <div class="w-5 h-5 bg-[#4DBC15] rounded flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12.5 3.5v5.8H6.3V24h5.5V12.5h5.9V24h5.5V3.5z"/></svg>
            </div>
            <span class="font-bold text-xs text-gray-900">Houzz</span>
          </div>
          <div class="trust-chip">
            <div class="w-5 h-5 bg-[#FF6153] rounded flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="font-bold text-xs text-gray-900">Angi</span>
          </div>
          <div class="trust-chip">
            <div class="w-5 h-5 bg-[#F68B24] rounded flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
            </div>
            <span class="font-bold text-xs text-gray-900">HomeAdvisor</span>
          </div>
          <!-- Set 2 (duplicate for seamless loop) -->
          <div class="trust-chip">
            <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span class="font-bold text-xs text-gray-900">{SITE.reviews.rating}</span>
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3 h-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
          </div>
          <div class="trust-chip">
            <div class="w-5 h-5 bg-[#005A8B] rounded flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-1 6h2v2h-2V7zm0 4h2v6h-2v-6z"/></svg>
            </div>
            <span class="font-bold text-xs text-[#005A8B]">BBB A+</span>
          </div>
          <div class="trust-chip">
            <div class="w-5 h-5 bg-[#4DBC15] rounded flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12.5 3.5v5.8H6.3V24h5.5V12.5h5.9V24h5.5V3.5z"/></svg>
            </div>
            <span class="font-bold text-xs text-gray-900">Houzz</span>
          </div>
          <div class="trust-chip">
            <div class="w-5 h-5 bg-[#FF6153] rounded flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="font-bold text-xs text-gray-900">Angi</span>
          </div>
          <div class="trust-chip">
            <div class="w-5 h-5 bg-[#F68B24] rounded flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
            </div>
            <span class="font-bold text-xs text-gray-900">HomeAdvisor</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .trust-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: white;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 9999px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .trust-marquee {
    position: relative;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .trust-marquee-track {
    display: flex;
    gap: 12px;
    width: max-content;
    animation: marquee-scroll 20s linear infinite;
  }

  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
