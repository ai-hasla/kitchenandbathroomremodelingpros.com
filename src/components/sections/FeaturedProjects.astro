---
import Container from '@/components/ui/Container.astro';

const projects = [
  {
    title: 'Modern Kitchen Remodel',
    location: 'Capitol Hill, Seattle',
    type: 'Kitchen',
    image: '/images/gallery-blue-kitchen.jpg',
    alt: 'Modern white kitchen with sleek cabinetry and quartz countertops',
  },
  {
    title: 'Spa-Inspired Bathroom',
    location: 'Bellevue',
    type: 'Bathroom',
    image: '/images/gallery-master-bath.jpg',
    alt: 'Luxurious spa-style bathroom with freestanding soaking tub',
  },
  {
    title: 'Open-Concept Kitchen',
    location: 'Kirkland',
    type: 'Kitchen',
    image: '/images/gallery-cozy-kitchen.jpg',
    alt: 'Bright open-concept kitchen with island and pendant lighting',
  },
  {
    title: 'Luxury Master Bath',
    location: 'Sammamish',
    type: 'Bathroom',
    image: '/images/gallery-walnut-kitchen.jpg',
    alt: 'Elegant master bathroom with double vanity and marble tile',
  },
  {
    title: 'Farmhouse Kitchen',
    location: 'Redmond',
    type: 'Kitchen',
    image: '/images/gallery-classic-bath.jpg',
    alt: 'Farmhouse-style kitchen with shaker cabinets and apron sink',
  },
  {
    title: 'Contemporary Bathroom',
    location: 'Mercer Island',
    type: 'Bathroom',
    image: '/images/gallery-green-kitchen.jpg',
    alt: 'Contemporary bathroom with walk-in shower and floating vanity',
  },
];
---

<section class="py-16 lg:py-24 bg-light">
  <Container>
    <!-- Section Header -->
    <div class="text-center mb-12" data-reveal>
      <h2 class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">
        Our Recent Projects
      </h2>
      <p class="text-body-text text-lg max-w-2xl mx-auto">
        Browse our portfolio of kitchen and bathroom transformations across the Greater Seattle area
      </p>
    </div>
  </Container>

  <!-- Projects Grid -->
  <Container>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-reveal-stagger>
      {projects.map((project) => (
        <a href="/gallery/" class="group">
          <div class="aspect-[4/3] rounded-xl overflow-hidden relative mb-4">
            <img
              src={project.image}
              alt={project.alt}
              width="800"
              height="600"
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-primary/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <div class="text-center text-white">
                <p class="text-lg font-semibold font-[family-name:var(--font-heading)]">{project.title}</p>
                <p class="text-sm text-white/80">{project.location}</p>
              </div>
            </div>
          </div>
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-semibold text-dark-text group-hover:text-accent transition-colors">{project.title}</h3>
              <p class="text-sm text-muted">{project.location}</p>
            </div>
            <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium flex-shrink-0 ${
              project.type === 'Kitchen'
                ? 'bg-accent-light text-accent'
                : 'bg-primary/10 text-primary'
            }`}>
              {project.type}
            </span>
          </div>
        </a>
      ))}
    </div>
  </Container>

  <!-- View Full Gallery Link -->
  <div class="text-center mt-10" data-reveal>
    <a
      href="/gallery/"
      class="inline-flex items-center gap-2 text-accent font-semibold hover:gap-3 transition-all duration-300"
    >
      View Full Gallery
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>

