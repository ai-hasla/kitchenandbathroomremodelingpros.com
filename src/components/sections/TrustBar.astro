---
import Container from '@/components/ui/Container.astro';
import { SITE } from '@/lib/constants';
---

<section class="bg-light py-10 lg:py-14">
  <Container>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 text-center" data-reveal-stagger>
      <!-- Years of Experience -->
      <div class="flex flex-col items-center">
        <div class="flex items-center gap-2 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
        </div>
        <div class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-primary">
          {new Date().getFullYear() - SITE.yearFounded}+
        </div>
        <p class="text-sm text-muted mt-1 font-[family-name:var(--font-body)]">Years of Experience</p>
      </div>

      <!-- Projects Completed -->
      <div class="flex flex-col items-center">
        <div class="flex items-center gap-2 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
        </div>
        <div class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-primary">
          {SITE.projects}+
        </div>
        <p class="text-sm text-muted mt-1 font-[family-name:var(--font-body)]">Projects Completed</p>
      </div>

      <!-- Google Rating -->
      <div class="flex flex-col items-center">
        <div class="flex items-center gap-2 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
        </div>
        <div class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-primary">
          {SITE.reviews.rating}
        </div>
        <p class="text-sm text-muted mt-1 font-[family-name:var(--font-body)]">Star Google Rating</p>
      </div>

      <!-- Satisfaction Guarantee -->
      <div class="flex flex-col items-center">
        <div class="flex items-center gap-2 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <div class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-primary">
          100%
        </div>
        <p class="text-sm text-muted mt-1 font-[family-name:var(--font-body)]">Satisfaction Guarantee</p>
      </div>
    </div>
  </Container>
</section>
