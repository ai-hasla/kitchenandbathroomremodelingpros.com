---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';

const posts = [
  {
    category: 'Cost Guide',
    title: 'Kitchen Remodel Cost in Seattle: 2026 Complete Guide',
    excerpt: 'Everything you need to know about kitchen remodeling costs in the Seattle area, from budget-friendly refreshes to luxury renovations.',
    date: 'March 5, 2026',
    readTime: '8 min read',
    image: '/images/blog-kitchen-ideas.jpg',
    slug: '/cost-guides/kitchen-remodel-cost-seattle/',
  },
  {
    category: 'Design Tips',
    title: '10 Bathroom Remodel Ideas That Add Value to Your Seattle Home',
    excerpt: 'Discover the bathroom upgrades that offer the highest ROI for Pacific Northwest homeowners.',
    date: 'February 28, 2026',
    readTime: '6 min read',
    image: '/images/blog-bathroom-ideas.jpg',
    slug: '/blog/bathroom-remodel-ideas-seattle/',
  },
  {
    category: 'Planning',
    title: 'Do You Need a Permit to Remodel in Seattle? Complete Guide',
    excerpt: "Navigate Seattle's permit requirements for kitchen and bathroom remodels. When you need one and when you don't.",
    date: 'February 20, 2026',
    readTime: '5 min read',
    image: '/images/blog-modern-kitchen.jpg',
    slug: '/blog/do-you-need-permit-remodel-seattle/',
  },
];
---

<section class="bg-light py-16 lg:py-24">
  <Container>
    <!-- Section Header -->
    <div class="text-center mb-12 lg:mb-16" data-reveal>
      <h2 class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">
        Remodeling Tips & Inspiration
      </h2>
      <p class="text-body-text text-lg max-w-2xl mx-auto">
        Expert advice to help you plan your next project
      </p>
    </div>

    <!-- Blog Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" data-reveal-stagger>
      {posts.map((post) => (
        <a href={post.slug} class="group rounded-2xl overflow-hidden border border-border bg-white flex flex-col">
          <!-- Image -->
          <div class="aspect-[16/9] overflow-hidden">
            <picture>
              <source srcset={post.image.replace('.jpg', '.webp')} type="image/webp" />
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                width="800"
                height="450"
                loading="lazy"
                decoding="async"
              />
            </picture>
          </div>

          <!-- Content -->
          <div class="p-5 lg:p-6 flex flex-col flex-1">
            <!-- Category Tag -->
            <span class="text-xs bg-accent-light text-accent px-2 py-1 rounded-full font-medium self-start mb-3">
              {post.category}
            </span>

            <!-- Title -->
            <h3 class="text-lg font-semibold text-dark-text line-clamp-2 group-hover:text-accent transition-colors duration-300 mb-2">
              {post.title}
            </h3>

            <!-- Excerpt -->
            <p class="text-sm text-muted line-clamp-2 flex-1 mb-4">
              {post.excerpt}
            </p>

            <!-- Date + Read Time -->
            <div class="flex items-center gap-2 text-xs text-muted mt-auto">
              <time>{post.date}</time>
              <span>&middot;</span>
              <span>{post.readTime}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Read More Link -->
    <div class="text-center mt-10 lg:mt-12" data-reveal>
      <Button variant="ghost" href="/blog/" size="md">
        Read More Articles
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </Button>
    </div>
  </Container>
</section>
