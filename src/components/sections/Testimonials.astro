---
import Container from '@/components/ui/Container.astro';
import { SITE } from '@/lib/constants';

const testimonials = [
  {
    name: 'Angela M.',
    location: '1925 Tudor — Queen Anne, Seattle · Kitchen Remodel, Jan 2025',
    text: "We just finished a full kitchen gut with these guys and I'm still kind of in shock at how good it turned out. New cabinets, Caesarstone counters, subway tile backsplash, and they moved the gas line so we could put the range on the island. The house is almost 100 years old so nothing was level or square — they dealt with it without complaining. Took about 7 weeks and came in $2k under the estimate somehow.",
  },
  {
    name: 'Kevin P.',
    location: 'Townhouse — Kirkland, WA · Bathroom Remodel, Nov 2024',
    text: "Had them redo our master bathroom. Ripped out the old fiberglass insert and put in a tiled shower with a linear drain and a niche for shampoo. Heated floors too which are amazing in winter. My only note is I wish we'd gone with the larger format tile they suggested — the smaller mosaic on the shower floor is a little harder to keep clean. But the workmanship is solid and the crew was super respectful of our space.",
  },
  {
    name: 'Brian & Stacy R.',
    location: '1960s Split-level — Ballard, Seattle · Kitchen Remodel, Sep 2024',
    text: "So we originally called them just for a countertop replacement but ended up doing a full kitchen remodel after seeing their portfolio. New layout, soft-close drawers, quartz island with seating, undercabinet LEDs — the whole nine. They found some old cast iron plumbing during demo and replaced it at cost. That kind of honesty is rare. We've already sent two neighbors their way.",
  },
];
---

<section class="bg-light py-16 lg:py-24">
  <Container>
    <!-- Section Header -->
    <div class="text-center mb-12 lg:mb-16" data-reveal>
      <h2 class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-primary mb-4">
        Straight from Seattle Homeowners
      </h2>
      <p class="text-body-text text-lg max-w-2xl mx-auto">
        Real projects, real neighborhoods, real numbers &mdash; not stock testimonials
      </p>
    </div>

    <!-- Testimonial Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" data-reveal-stagger>
      {testimonials.map((testimonial) => (
        <div class="bg-white rounded-2xl p-6 lg:p-8 shadow-sm border border-border flex flex-col">
          <!-- 5 Gold Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote Text -->
          <p class="text-body-text leading-relaxed italic flex-1 mb-6">
            "{testimonial.text}"
          </p>

          <!-- Divider -->
          <div class="border-t border-border pt-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="font-semibold text-dark-text">{testimonial.name}</p>
                <p class="text-sm text-muted">{testimonial.location}</p>
              </div>
              <!-- Google Review Badge -->
              <div class="flex items-center gap-1.5 text-muted">
                <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4" />
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                </svg>
                <span class="text-xs font-medium">Google</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
