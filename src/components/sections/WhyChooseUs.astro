---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
---

<section class="py-16 lg:py-24">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Image -->
      <div class="aspect-[3/4] rounded-2xl overflow-hidden" data-reveal="left">
        <img
          src="/images/showroom.jpg"
          alt="Beautifully remodeled spa-style bathroom with freestanding tub"
          class="h-full w-full object-cover transition-transform duration-700 hover:scale-105"
          loading="lazy"
        />
      </div>

      <!-- Right: Content -->
      <div data-reveal="right">
        <p class="text-accent uppercase tracking-widest text-sm font-semibold mb-4 font-[family-name:var(--font-body)]">
          WHY CHOOSE US
        </p>

        <h2 class="text-3xl lg:text-4xl font-[family-name:var(--font-heading)] text-primary leading-tight mb-6">
          We Know Seattle Homes Inside and Out
        </h2>

        <p class="text-body-text leading-relaxed mb-4 max-w-lg">
          We've been remodeling Seattle kitchens and bathrooms since 2010. We know that
          the Craftsman bungalows in Ballard need different solutions than the mid-century
          ramblers in Bellevue or the new builds in Sammamish. We know which walls in a
          1940s Capitol Hill condo are load-bearing before we even open them up. That kind
          of knowledge only comes from doing this work in this city, year after year.
        </p>
        <p class="text-body-text leading-relaxed mb-10 max-w-lg">
          Every project gets a dedicated lead carpenter &mdash; not a rotating crew of
          strangers. You'll have one point of contact who knows your name, your project,
          and exactly where things stand every single day.
        </p>

        <!-- 2x2 Value Propositions Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mb-10">
          <!-- 1. Expert Craftsmanship -->
          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.384-3.073A2.25 2.25 0 014.5 10.03V6.75a2.25 2.25 0 011.536-2.127l5.384-1.81a2.25 2.25 0 011.46 0l5.384 1.81A2.25 2.25 0 0119.5 6.75v3.28a2.25 2.25 0 01-1.536 2.067l-5.384 3.073a2.25 2.25 0 01-2.22 0zM12 9.5v0" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 12L12 14.25 14.25 12" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark-text mb-1">We Measure Twice</h3>
              <p class="text-sm text-muted leading-relaxed">Every cabinet, tile line, and countertop gets a 47-point quality check before we call it done</p>
            </div>
          </div>

          <!-- 2. Transparent Pricing -->
          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark-text mb-1">Your Price Is Your Price</h3>
              <p class="text-sm text-muted leading-relaxed">Fixed-price contracts, not estimates. No change-order games &mdash; the number we quote is the number you pay</p>
            </div>
          </div>

          <!-- 3. Licensed & Insured -->
          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark-text mb-1">Fully Permitted, Every Time</h3>
              <p class="text-sm text-muted leading-relaxed">We pull all Seattle SDCI permits ourselves and schedule every inspection &mdash; you never have to visit the permit office</p>
            </div>
          </div>

          <!-- 4. On-Time Delivery -->
          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark-text mb-1">We Live in Your Timeline</h3>
              <p class="text-sm text-muted leading-relaxed">Materials ordered before demo day. Subs scheduled weeks ahead. Average kitchen: 3&ndash;5 weeks, average bath: 2&ndash;3 weeks</p>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <Button variant="outline" href="/about/#process">
          Learn About Our Process
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
      </div>
    </div>
  </Container>
</section>
